<style is:global>
  /* is:global: parte do DOM desta página é criada via JS e não recebe o
     atributo de escopo do Astro — estilos com escopo não a alcançariam */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:      #FFFFFF;
    --bg2:     #FAFAF9;
    --ink:     #18181B;
    --body:    #52525B;
    --muted:   #A1A1AA;
    --line:    #E4E4E7;
    --line2:   #F4F4F5;
    --accent:  #F59E0B;
    --accent-ink: #B45309;
    --accent-soft: #FFFBEB;
    --green:   #15803D;
  }

  html, body { overflow-x: hidden; max-width: 100%; min-height: 100%; }
  html { font-family: 'Inter', system-ui, -apple-system, sans-serif; font-size: 16px; -webkit-font-smoothing: antialiased; background: var(--bg2); color: var(--ink); }
  a { color: inherit; text-decoration: none; }

  .topbar { background: rgba(255,255,255,.9); border-bottom: 1px solid var(--line); }
  .topbar-in { max-width: 1064px; margin: 0 auto; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; height: 60px; }
  .brand { font-size: 15px; font-weight: 700; letter-spacing: -.02em; display: flex; align-items: center; gap: 8px; }
  .brand-dot { width: 10px; height: 10px; border-radius: 3px; background: var(--accent); display: inline-block; }
  .topbar .tiny a { text-decoration: underline; text-underline-offset: 3px; }

  .stage { max-width: 680px; margin: 0 auto; padding: 40px 20px 80px; }
  @media (max-width: 640px) { .stage { padding: 24px 16px 64px; } }

  /* progress */
  .progress { height: 4px; background: var(--line2); border-radius: 999px; overflow: hidden; margin-bottom: 28px; }
  .progress-bar { height: 100%; width: 0%; background: var(--accent); border-radius: 999px; transition: width .3s ease; }
  .step-label { font-size: 12.5px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--accent-ink); margin-bottom: 14px; }

  .qcard { background: var(--bg); border: 1px solid var(--line); border-radius: 18px; padding: 36px 32px; box-shadow: 0 20px 50px -35px rgba(24,24,27,.3); }
  @media (max-width: 640px) { .qcard { padding: 26px 20px; } }
  .qtitle { font-size: clamp(22px, 3.4vw, 30px); font-weight: 700; letter-spacing: -.025em; line-height: 1.15; margin-bottom: 8px; }
  .qsub { font-size: 15px; color: var(--body); line-height: 1.6; margin-bottom: 24px; }

  .opts { display: grid; gap: 10px; }
  .opt {
    display: flex; align-items: center; gap: 12px; width: 100%;
    background: var(--bg); border: 1px solid var(--line); border-radius: 12px;
    padding: 16px 18px; font-size: 15.5px; font-weight: 500; color: var(--ink);
    cursor: pointer; text-align: left; font-family: inherit;
    transition: border-color .12s, background .12s, transform .1s;
  }
  .opt:hover { border-color: var(--ink); transform: translateY(-1px); }
  .opt .dot { width: 18px; height: 18px; border-radius: 50%; border: 2px solid var(--line); flex-shrink: 0; }
  .opt:hover .dot { border-color: var(--accent); }

  .backlink { background: none; border: none; font-family: inherit; font-size: 13.5px; color: var(--muted); cursor: pointer; margin-top: 18px; text-decoration: underline; text-underline-offset: 3px; }
  .backlink:hover { color: var(--ink); }

  /* buttons */
  .btn-dark {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    background: var(--ink); color: #fff;
    font-size: 15px; font-weight: 600;
    padding: 15px 28px; border-radius: 10px; border: none; cursor: pointer;
    transition: transform .12s, box-shadow .15s, background .15s;
    box-shadow: 0 1px 2px rgba(0,0,0,.12);
    font-family: inherit;
  }
  .btn-dark:hover { background: #000; transform: translateY(-1px); box-shadow: 0 6px 16px -6px rgba(0,0,0,.35); }
  .btn-ghost {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    background: var(--bg); color: var(--ink);
    font-size: 15px; font-weight: 600;
    padding: 15px 28px; border-radius: 10px; border: 1px solid var(--line); cursor: pointer;
    transition: border-color .15s, transform .12s; font-family: inherit;
  }
  .btn-ghost:hover { border-color: var(--ink); transform: translateY(-1px); }

  /* gate form */
  .field { margin-bottom: 14px; }
  .field label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; }
  .field input { width: 100%; border: 1px solid var(--line); background: var(--bg2); padding: 13px 15px; font-size: 15px; font-family: inherit; color: var(--ink); border-radius: 10px; }
  .field input:focus { outline: 2px solid var(--accent); outline-offset: -1px; }
  .gate-error { display: none; font-size: 13px; color: #B91C1C; margin-top: 10px; }

  /* result */
  .r-kicker { display: inline-flex; align-items: center; gap: 8px; font-size: 12.5px; font-weight: 600; letter-spacing: .02em; color: var(--accent-ink); background: var(--accent-soft); border: 1px solid #FDE68A; border-radius: 999px; padding: 6px 14px; margin-bottom: 18px; }
  .r-title { font-size: clamp(26px, 4vw, 36px); font-weight: 700; letter-spacing: -.028em; line-height: 1.12; margin-bottom: 20px; }
  .r-lines { margin-bottom: 8px; }
  .r-line { display: flex; gap: 12px; align-items: flex-start; padding: 12px 0; border-top: 1px solid var(--line2); font-size: 15px; line-height: 1.6; color: var(--body); }
  .r-line:first-child { border-top: none; }
  .r-line svg { width: 18px; height: 18px; stroke: var(--accent-ink); flex-shrink: 0; margin-top: 3px; }
  .r-honest { background: var(--bg2); border: 1px solid var(--line); border-radius: 12px; padding: 16px 18px; font-size: 13.5px; color: var(--body); line-height: 1.6; margin: 20px 0 24px; }
  .r-honest strong { color: var(--ink); }

  .lesson-tabs { display: flex; gap: 8px; margin: 20px 0 12px; }
  .lesson-tab { flex: 1; background: var(--bg); border: 1px solid var(--line); border-radius: 10px; padding: 12px; font-size: 13.5px; font-weight: 600; color: var(--body); cursor: pointer; font-family: inherit; transition: border-color .12s, color .12s; }
  .lesson-tab.active { border-color: var(--accent); color: var(--accent-ink); background: var(--accent-soft); }
  .r-video video { width: 100%; display: block; background: #000; aspect-ratio: 16 / 9; border: 1px solid var(--line); border-radius: 12px; }
  .r-locked { font-size: 13px; color: var(--muted); margin-top: 12px; line-height: 1.6; }
  .r-locked a { color: var(--accent-ink); text-decoration: underline; text-underline-offset: 3px; }

  .fade-in { animation: fadeIn .3s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
</style>
</head>
