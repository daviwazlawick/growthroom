---
import '../styles/global.css';
import MetaEventId from '../components/MetaEventId.astro';
import CookieBanner from '../components/CookieBanner.astro';

const GTM_ID = import.meta.env.PUBLIC_GTM_ID || "GTM-TD9BJC9F";
const USERCENTRICS_SETTINGS_ID = import.meta.env.PUBLIC_USERCENTRICS_SETTINGS_ID || "";
const CHECKOUT_URL = "https://alfima.com/daviwazl/ads-blueprint/purchase";
---

<!doctype html>
<html lang="en">
<head>
  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-KL573474');</script>
  <!-- End Google Tag Manager -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <MetaEventId />
  <script is:inline>
    if (typeof navigator !== 'undefined' && 'registerProtocolHandler' in navigator) {
      navigator.registerProtocolHandler = function () {};
    }
  </script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){window.dataLayer.push(arguments);}
    window.gtag = window.gtag || gtag;
    gtag('consent', 'default', {
      analytics_storage: 'denied',
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
      functionality_storage: 'granted',
      security_storage: 'granted',
      wait_for_update: 1500
    });
  </script>
  {USERCENTRICS_SETTINGS_ID && (
    <>
      <script id="usercentrics-cmp" async src="https://app.usercentrics.eu/browser-ui/latest/loader.js" data-settings-id={USERCENTRICS_SETTINGS_ID}></script>
      <script is:inline>
        (function(){
          function toGranted(v){return v?'granted':'denied';}
          function readConsentState(){
            var analytics=false,marketing=false;
            try{
              if(window.UC_UI&&typeof window.UC_UI.getServicesBaseInfo==='function'){
                var services=window.UC_UI.getServicesBaseInfo()||[];
                for(var i=0;i<services.length;i++){
                  var svc=services[i];
                  var name=(svc.name||'').toLowerCase();
                  var cat=(svc.categorySlug||svc.category||'').toLowerCase();
                  var granted=!!(svc.consent&&svc.consent.status);
                  if(!granted)continue;
                  if(cat.indexOf('marketing')!==-1||name.indexOf('facebook')!==-1||name.indexOf('ads')!==-1)marketing=true;
                  if(cat.indexOf('analytics')!==-1||name.indexOf('analytics')!==-1)analytics=true;
                }
              }
            }catch(_){}
            return{analytics:analytics,marketing:marketing};
          }
          function applyConsentModeV2(){
            var state=readConsentState();
            window.gtag('consent','update',{analytics_storage:toGranted(state.analytics),ad_storage:toGranted(state.marketing),ad_user_data:toGranted(state.marketing),ad_personalization:toGranted(state.marketing)});
            window.dispatchEvent(new CustomEvent('growthroom:consent-updated',{detail:state}));
          }
          function registerHooks(){
            applyConsentModeV2();
            window.addEventListener('UC_UI_INITIALIZED',applyConsentModeV2);
            window.addEventListener('UC_UI_VIEW_CHANGED',applyConsentModeV2);
            window.addEventListener('UC_CONSENT',applyConsentModeV2);
          }
          if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',registerHooks);
          else registerHooks();
          window.getGrowthroomConsentState=readConsentState;
          window.openPrivacySettings=function(){
            try{
              if(window.UC_UI&&typeof window.UC_UI.showSecondLayer==='function'){window.UC_UI.showSecondLayer();return;}
              if(window.UC_UI&&typeof window.UC_UI.showFirstLayer==='function')window.UC_UI.showFirstLayer();
            }catch(_){}
          };
        })();
      </script>
    </>
  )}
  <script is:inline define:vars={{ GTM_ID }}>
    (function(){
      function loadGtmOnce(){
        if(!GTM_ID||window.__growthroomGtmLoaded)return;
        window.__growthroomGtmLoaded=true;
        window.dataLayer=window.dataLayer||[];
        window.dataLayer.push({'gtm.start':new Date().getTime(),event:'gtm.js'});
        var f=document.getElementsByTagName('script')[0];
        var j=document.createElement('script');
        j.async=true;
        j.src='https://www.googletagmanager.com/gtm.js?id='+GTM_ID;
        f.parentNode.insertBefore(j,f);
      }
      function shouldLoad(){
        return document.cookie.indexOf('growthroom_cookie_choice_v1=accepted')!==-1||
          document.cookie.indexOf('growthroom_cookie_choice_v1=customized')!==-1;
      }
      if(shouldLoad()){
        gtag('consent','update',{analytics_storage:'granted',ad_storage:'granted',ad_user_data:'granted',ad_personalization:'granted'});
        loadGtmOnce();
      }
      window.addEventListener('growthroom:consent-updated',function(e){
        var d=e&&e.detail?e.detail:{};
        if(d.analytics||d.marketing)loadGtmOnce();
      });
    })();
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" onload="this.onload=null;this.rel='stylesheet'" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Montserrat:wght@700;800;900&display=swap" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Montserrat:wght@700;800;900&display=swap" /></noscript>
  <link rel="icon" type="image/png" href="/img/logo.png" />
  <meta name="description" content="Launch your first Meta Ads campaign today. Step-by-step training showing complete beginners exactly how to launch Meta Ads correctly — without agencies, confusion or wasted ad spend." />
  <meta name="robots" content="noindex, nofollow" />
  <meta property="og:title" content="Launch Ads Blueprint — Launch Your First Meta Ads Campaign Today" />
  <meta property="og:description" content="Step-by-step training showing complete beginners exactly how to launch Meta Ads correctly." />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://growthroom.eu/img/logo.png" />
  <title>Launch Ads Blueprint — Launch Your First Meta Ads Campaign Today</title>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #FFFFFF;
      --bg2: #F9F9F9;
      --bg3: #F3F3F3;
      --text: #111111;
      --text2: #444444;
      --text3: #777777;
      --accent: #F5A623;
      --accent-dark: #D4880A;
      --dark: #111111;
      --line: #E5E5E5;
      --font-head: 'Montserrat', 'Inter', sans-serif;
      --font-body: 'Inter', sans-serif;
      --max: 860px;
      --pad: clamp(20px, 5vw, 40px);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }

    .wrap {
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 var(--pad);
    }

    /* ---- REVEAL ANIMATIONS ---- */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.65s ease, transform 0.65s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .reveal.visible {
      opacity: 1;
      transform: none;
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }

    /* ---- STICKY NAV ---- */
    .lab-nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,0.96);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line);
    }
    .lab-nav-inner {
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 var(--pad);
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
      gap: 16px;
    }
    .lab-nav-logo {
      font-family: var(--font-head);
      font-weight: 800;
      font-size: 15px;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }
    .lab-nav-logo span {
      display: inline-block;
      width: 8px;
      height: 8px;
      background: var(--accent);
      border-radius: 50%;
    }
    .lab-nav-price {
      font-family: var(--font-head);
      font-weight: 800;
      font-size: 15px;
      color: var(--text3);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .lab-nav-price s { color: #aaa; font-weight: 500; font-size: 13px; }
    .btn-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--dark);
      color: var(--accent);
      font-family: var(--font-head);
      font-weight: 800;
      font-size: 14px;
      padding: 0 22px;
      height: 42px;
      border-radius: 6px;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, transform 0.2s;
      white-space: nowrap;
      letter-spacing: -0.01em;
    }
    .btn-cta:hover { background: #222; transform: translateY(-1px); }
    .btn-cta-lg {
      height: 56px;
      font-size: 17px;
      padding: 0 32px;
      border-radius: 8px;
      width: 100%;
      max-width: 480px;
      letter-spacing: -0.02em;
    }
    .btn-cta-xl {
      height: 64px;
      font-size: 19px;
      padding: 0 40px;
      border-radius: 8px;
      width: 100%;
      letter-spacing: -0.02em;
    }

    /* ---- HERO ---- */
    .hero {
      padding: clamp(48px, 8vw, 80px) 0 clamp(48px, 8vw, 72px);
      text-align: center;
      background: var(--bg);
    }
    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #FFF4E0;
      border: 1px solid #F5A623;
      color: #D4880A;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 5px 14px;
      border-radius: 999px;
      margin-bottom: 28px;
    }
    .hero h1 {
      font-family: var(--font-head);
      font-weight: 900;
      font-size: clamp(32px, 7vw, 62px);
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--text);
      margin-bottom: 24px;
      max-width: 720px;
      margin-left: auto;
      margin-right: auto;
    }
    .hero h1 .hl {
      color: var(--accent);
      position: relative;
      display: inline-block;
    }
    .hero-sub {
      font-size: clamp(17px, 2.5vw, 20px);
      color: var(--text2);
      max-width: 580px;
      margin: 0 auto 36px;
      line-height: 1.55;
    }
    .hero-cta-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
    .hero-micro {
      font-size: 13px;
      color: var(--text3);
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .hero-micro .dot { color: var(--accent); }
    .hero-photo-placeholder {
      margin: 48px auto 0;
      max-width: 680px;
      background: var(--bg3);
      border: 2px dashed var(--line);
      border-radius: 12px;
      height: 360px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 12px;
      color: var(--text3);
      font-size: 14px;
    }
    .hero-photo-placeholder .icon { font-size: 36px; }
    .hero-trust-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: clamp(16px, 4vw, 40px);
      margin-top: 40px;
      flex-wrap: wrap;
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: var(--text2);
      font-weight: 500;
    }
    .trust-item .check {
      width: 20px;
      height: 20px;
      background: var(--accent);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      color: #fff;
      flex-shrink: 0;
    }

    /* ---- SECTION SHARED ---- */
    .section {
      padding: clamp(56px, 9vw, 96px) 0;
    }
    .section-alt {
      background: var(--bg2);
    }
    .section-dark {
      background: var(--dark);
      color: #fff;
    }
    .section-label {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 16px;
    }
    .section-dark .section-label { color: var(--accent); }
    .section-h2 {
      font-family: var(--font-head);
      font-weight: 900;
      font-size: clamp(26px, 5vw, 44px);
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--text);
      margin-bottom: 16px;
    }
    .section-dark .section-h2 { color: #fff; }
    .section-lead {
      font-size: clamp(16px, 2vw, 18px);
      color: var(--text2);
      max-width: 600px;
      margin-bottom: 48px;
      line-height: 1.6;
    }
    .section-dark .section-lead { color: rgba(255,255,255,0.7); }
    .center { text-align: center; }
    .center .section-lead { margin-left: auto; margin-right: auto; }

    /* ---- SECTION 2: WHY FAIL ---- */
    .fail-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 40px;
    }
    .fail-card {
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 24px;
      position: relative;
    }
    .fail-card .fail-icon {
      font-size: 28px;
      margin-bottom: 12px;
    }
    .fail-card h3 {
      font-family: var(--font-head);
      font-weight: 800;
      font-size: 16px;
      color: var(--text);
      margin-bottom: 8px;
    }
    .fail-card p {
      font-size: 14px;
      color: var(--text2);
      line-height: 1.55;
    }
    .fail-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: #F3F3F3;
      border-radius: 10px 10px 0 0;
    }
    .fail-card.hot::before { background: var(--accent); }

    /* ---- SECTION 3: OPPORTUNITY ---- */
    .opp-box {
      background: var(--dark);
      border-radius: 14px;
      padding: clamp(32px, 5vw, 56px);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .opp-box::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(245,166,35,0.18), transparent 60%);
    }
    .opp-box h2 {
      font-family: var(--font-head);
      font-weight: 900;
      font-size: clamp(26px, 5vw, 44px);
      letter-spacing: -0.03em;
      color: #fff;
      margin-bottom: 20px;
      position: relative;
      line-height: 1.1;
    }
    .opp-box h2 span { color: var(--accent); }
    .opp-box p {
      font-size: clamp(16px, 2vw, 18px);
      color: rgba(255,255,255,0.75);
      max-width: 560px;
      margin: 0 auto 32px;
      line-height: 1.6;
      position: relative;
    }
    .opp-steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 40px;
      position: relative;
    }
    .opp-step {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px;
      padding: 20px;
    }
    .opp-step .num {
      font-family: var(--font-head);
      font-weight: 900;
      font-size: 36px;
      color: var(--accent);
      line-height: 1;
      margin-bottom: 8px;
    }
    .opp-step p {
      font-size: 13px;
      color: rgba(255,255,255,0.65);
      margin: 0;
    }

    /* ---- SECTION 4: MODULES ---- */
    .modules-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 40px;
    }
    .module-card {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 20px;
      transition: border-color 0.2s, transform 0.2s;
    }
    .module-card:hover {
      border-color: var(--accent);
      transform: translateY(-2px);
    }
    .module-icon {
      width: 44px;
      height: 44px;
      background: #FFF4E0;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
    }
    .module-info h3 {
      font-family: var(--font-head);
      font-weight: 800;
      font-size: 14px;
      color: var(--text);
      margin-bottom: 4px;
    }
    .module-info p {
      font-size: 13px;
      color: var(--text3);
      line-height: 1.45;
    }
    .module-num {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 2px;
    }

    /* ---- SECTION 5: OUTCOMES ---- */
    .outcomes-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 1px solid var(--line);
      border-radius: 12px;
      overflow: hidden;
      margin-top: 40px;
    }
    .outcome-row {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 20px 24px;
      border-bottom: 1px solid var(--line);
      background: var(--bg);
      transition: background 0.2s;
    }
    .outcome-row:last-child { border-bottom: none; }
    .outcome-row:hover { background: #FFFBF3; }
    .outcome-check {
      width: 28px;
      height: 28px;
      background: var(--accent);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 14px;
      color: #fff;
      font-weight: 700;
    }
    .outcome-text {
      font-size: 16px;
      color: var(--text);
      font-weight: 500;
    }

    /* ---- SECTION 6: PROOF ---- */
    .proof-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 40px;
    }
    .proof-placeholder {
      background: var(--bg3);
      border: 2px dashed var(--line);
      border-radius: 10px;
      height: 200px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 8px;
      color: var(--text3);
      font-size: 13px;
      font-weight: 500;
    }
    .proof-placeholder .icon { font-size: 28px; }
    .proof-placeholder.tall { height: 280px; }

    .testimonials-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 16px;
    }
    .tcard {
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .tcard .stars {
      color: var(--accent);
      font-size: 16px;
      letter-spacing: 2px;
    }
    .tcard blockquote {
      font-size: 15px;
      color: var(--text);
      line-height: 1.6;
      font-style: italic;
      flex: 1;
    }
    .tcard blockquote strong { font-style: normal; color: var(--text); }
    .tcard .tperson {
      display: flex;
      align-items: center;
      gap: 12px;
      border-top: 1px solid var(--line);
      padding-top: 16px;
    }
    .avatar-ph {
      width: 40px;
      height: 40px;
      background: var(--bg3);
      border: 1px dashed var(--line);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      color: var(--text3);
      flex-shrink: 0;
    }
    .tperson-info .name { font-size: 14px; font-weight: 700; color: var(--text); }
    .tperson-info .role { font-size: 12px; color: var(--text3); }

    /* ---- SECTION 7: BONUSES ---- */
    .bonus-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-top: 40px;
    }
    .bonus-card {
      display: flex;
      align-items: center;
      gap: 20px;
      background: var(--bg);
      border: 1px solid var(--line);
      border-left: 4px solid var(--accent);
      border-radius: 10px;
      padding: 20px 24px;
      transition: transform 0.2s;
    }
    .bonus-card:hover { transform: translateX(4px); }
    .bonus-badge {
      background: var(--accent);
      color: var(--dark);
      font-family: var(--font-head);
      font-weight: 800;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 4px;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .bonus-info h3 {
      font-family: var(--font-head);
      font-weight: 800;
      font-size: 16px;
      color: var(--text);
      margin-bottom: 4px;
    }
    .bonus-info p {
      font-size: 13px;
      color: var(--text3);
    }
    .bonus-value {
      margin-left: auto;
      font-family: var(--font-head);
      font-weight: 900;
      font-size: 14px;
      color: var(--text3);
      white-space: nowrap;
      flex-shrink: 0;
    }
    .bonus-value s { color: #bbb; font-weight: 500; }
