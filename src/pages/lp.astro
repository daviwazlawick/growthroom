<script is:inline>
/* ---------- Counter animation ---------- */
function animateCount(el){
  var to=parseFloat(el.dataset.to);
  var decimals=parseInt(el.dataset.decimals||'0',10);
  var thousands=el.dataset.thousands==='true';
  var prefix=el.dataset.prefix||'';
  var dur=1400;
  var start=performance.now();
  function fmt(v){
    var n=decimals?v.toFixed(decimals):Math.round(v).toString();
    if(thousands&&!decimals){n=Math.round(v).toLocaleString('de-DE').replace(/,/g,'.');}
    return prefix+n;
  }
  function tick(t){
    var p=Math.min(1,(t-start)/dur);
    var ease=1-Math.pow(1-p,3);
    el.textContent=fmt(to*ease);
    if(p<1)requestAnimationFrame(tick);
    else el.textContent=fmt(to);
  }
  requestAnimationFrame(tick);
}

/* ---------- Intersection observer ---------- */
var io=new IntersectionObserver(function(entries){
  entries.forEach(function(e){
    if(e.isIntersecting){
      e.target.classList.add('in');
      if(e.target.querySelectorAll){
        e.target.querySelectorAll('.count').forEach(function(c){
          if(!c.dataset.done){c.dataset.done='1';animateCount(c);}
        });
      }
      io.unobserve(e.target);
    }
  });
},{threshold:.15});
document.querySelectorAll('.fu').forEach(function(el){io.observe(el);});
document.querySelectorAll('.count').forEach(function(c){io.observe(c);});

/* ---------- FAQ ---------- */
document.querySelectorAll('.faq-item').forEach(function(item){
  var q=item.querySelector('.faq-q');
  q.addEventListener('click',function(){item.classList.toggle('open');});
  q.addEventListener('keydown',function(e){
    if(e.key==='Enter'||e.key===' '){e.preventDefault();item.classList.toggle('open');}
  });
});

/* ---------- Magnetic CTA ---------- */
(function(){
  var btn=document.getElementById('magneticCta');
  if(!btn)return;
  btn.addEventListener('mousemove',function(e){
    var r=btn.getBoundingClientRect();
    var x=e.clientX-(r.left+r.width/2);
    var y=e.clientY-(r.top+r.height/2);
    btn.style.transform='translate('+x*0.18+'px,'+y*0.25+'px)';
  });
  btn.addEventListener('mouseleave',function(){btn.style.transform='';});
})();

/* ---------- MCQ option groups ---------- */
function setupMCQ(rootId,multi){
  var root=document.getElementById(rootId);
  if(!root)return;
  root.querySelectorAll('.mcq-opt').forEach(function(b){
    b.addEventListener('click',function(){
      if(multi){
        b.classList.toggle('on');
      }else{
        root.querySelectorAll('.mcq-opt').forEach(function(x){x.classList.remove('on');});
        b.classList.add('on');
      }
      var field=b.closest('.field');
      if(field&&field.classList.contains('invalid'))validateStep(curStep);
    });
  });
}
setupMCQ('mcq-spend',false);
setupMCQ('mcq-channels',true);
setupMCQ('mcq-blocker',false);

/* ---------- Multi-step form ---------- */
var curStep=1;
var totalSteps=4;
var titles={
  1:'What stage are you at?',
  2:'Where are you running paid?',
  3:'What’s blocking you most?',
  4:'How do we reach you?'
};
var formTitle=document.getElementById('formTitle');
var stepLabel=document.getElementById('stepLabel');
var backBtn=document.getElementById('backBtn');
var nextBtn=document.getElementById('nextBtn');
var formErrorMsg=document.getElementById('formErrorMsg');

function setStep(n){
  curStep=n;
  document.querySelectorAll('.step-pane').forEach(function(p){
    p.classList.toggle('active',parseInt(p.dataset.pane,10)===n);
  });
  document.querySelectorAll('.pstep').forEach(function(p){
    var s=parseInt(p.dataset.step,10);
    p.classList.toggle('done',s<n);
    p.classList.toggle('active',s===n);
  });
  formTitle.textContent=titles[n];
  stepLabel.textContent='Step '+String(n).padStart(2,'0')+' of '+String(totalSteps).padStart(2,'0');
  backBtn.style.display=n>1?'inline-flex':'none';
  nextBtn.innerHTML=n===totalSteps?'Submit application <span class="arrow">→</span>':'Continue <span class="arrow">→</span>';
}

function validateStep(n){
  var ok=true;
  if(n===1){
    var sel=document.querySelectorAll('#mcq-spend .mcq-opt.on');
    setInvalid(document.querySelector('[data-field=spend]'),sel.length===0);
    ok=sel.length>0;
  }
  if(n===2){
    var sel=document.querySelectorAll('#mcq-channels .mcq-opt.on');
    setInvalid(document.querySelector('[data-field=channels]'),sel.length===0);
    ok=sel.length>0;
  }
  if(n===3){
    var sel=document.querySelectorAll('#mcq-blocker .mcq-opt.on');
    setInvalid(document.querySelector('[data-field=blocker]'),sel.length===0);
    ok=sel.length>0;
  }
  if(n===4){
    var name=document.getElementById('f-name');
    var email=document.getElementById('f-email');
    var phone=document.getElementById('f-phone');
    var nameOk=name.value.trim().length>=2;
    var emailOk=/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value);
    var phoneOk=phone.value.trim().length>=5;
    setInvalid(name,!nameOk);
    setInvalid(email,!emailOk);
    setInvalid(phone,!phoneOk);
    ok=nameOk&&emailOk&&phoneOk;
  }
  return ok;
}
function setInvalid(elOrField,bad){
  var field=elOrField&&elOrField.classList&&elOrField.classList.contains('field')?elOrField:elOrField&&elOrField.closest?elOrField.closest('.field'):null;
  if(!field)return;
  field.classList.toggle('invalid',bad);
}

backBtn.addEventListener('click',function(){if(curStep>1)setStep(curStep-1);});

nextBtn.addEventListener('click',function(){
  if(!validateStep(curStep))return;
  if(curStep<totalSteps){
    setStep(curStep+1);
  }else{
    submitForm();
  }
});

async function submitForm(){
  if(formErrorMsg)formErrorMsg.style.display='none';
  nextBtn.disabled=true;
  nextBtn.innerHTML='Sending…';

  var spend=document.querySelector('#mcq-spend .mcq-opt.on')?.dataset.val||'';
  var channelEls=document.querySelectorAll('#mcq-channels .mcq-opt.on');
  var channels=Array.from(channelEls).map(function(b){return b.dataset.val;}).join(', ');
  var blocker=document.querySelector('#mcq-blocker .mcq-opt.on')?.dataset.val||'';
  var fullName=document.getElementById('f-name').value.trim();
  var email=document.getElementById('f-email').value.trim();
  var phone=document.getElementById('f-phone').value.trim();

  var nameParts=fullName.split(/\s+/);
  var firstName=nameParts[0]||'';
  var lastName=nameParts.slice(1).join(' ')||'';

  var trackingPayload={};
  try{
    if(typeof window.submitMetaForm==='function'){
      trackingPayload=await window.submitMetaForm({firstName:firstName,lastName:lastName,email:email,phone:phone,channels:channels,monthlySpend:spend,biggestBlocker:blocker});
    }
  }catch(e){}

  try{
    var res=await fetch('/api/leads',{
      method:'POST',
      headers:{'content-type':'application/json'},
      body:JSON.stringify(Object.assign({},{fullName:fullName,email:email,phone:phone,channels:channels,monthlySpend:spend,biggestBlocker:blocker},trackingPayload))
    });
    if(!res.ok)throw new Error('api_error');

    document.querySelectorAll('.step-pane').forEach(function(p){p.classList.remove('active');});
    document.getElementById('successPane').classList.add('show');
    document.getElementById('formFoot').style.display='none';
    formTitle.textContent='Welcome to Cohort 04';
    document.getElementById('successEmail').textContent=email||'—';
    document.getElementById('successName').textContent='You’re in the queue, '+firstName+'.';
    document.querySelectorAll('.pstep').forEach(function(p){p.classList.add('done');p.classList.remove('active');});
  }catch(e){
    nextBtn.disabled=false;
    nextBtn.innerHTML='Submit application <span class="arrow">→</span>';
    if(formErrorMsg)formErrorMsg.style.display='block';
  }
}

['f-name','f-email','f-phone'].forEach(function(id){
  var el=document.getElementById(id);
  if(!el)return;
  el.addEventListener('input',function(){
    if(el.closest('.field').classList.contains('invalid'))validateStep(curStep);
  });
});

setStep(1);
</script>
</body>
