    .light-stats .lcell .ey{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#5A5A55}
    .light-stats .lcell .num{font-family:var(--serif);font-size:clamp(48px,6vw,76px);line-height:1;letter-spacing:-.03em;margin-top:14px;color:#1A1A1F;font-weight:380}
    .light-stats .lcell .num .suf{font-family:var(--sans);font-size:.32em;color:#5A5A55;font-weight:500;margin-left:6px;letter-spacing:0}
    .light-stats .lcell .desc{margin-top:14px;color:#5A5A55;font-size:14px;max-width:32ch}
    .form-shell.light{background:#FFFFFF;border:1px solid #E4DFD2;color:#1A1A1F;}
    .form-shell.light .form-head{border-bottom-color:#EDE7D6;background:#FAF7EE}
