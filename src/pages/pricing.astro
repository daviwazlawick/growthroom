---
import Layout from '../layouts/Layout.astro';

const iconCheck = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>`;

const iconUsers = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`;

const plans = [
  {
    name: '1-on-1 Private',
    price: '€169',
    groupLabel: 'Exclusive 1-on-1',
    featured: false,
    features: [
      'Fully personalised sessions',
      'Direct expert access',
      'Custom agenda every week',
      'Private session recordings',
      'Priority scheduling',
    ],
    cta: 'Get Started',
  },
  {
    name: 'Small Group',
    price: '€129',
    groupLabel: 'Up to 5 people',
    featured: true,
    features: [
      'Shared live coaching',
      'Peer learning & discussion',
      'Group session recordings',
      'Structured weekly topics',
      'Cost-efficient expert access',
    ],
    cta: 'Get Started',
  },
  {
    name: 'Group Room',
    price: '€99',
    groupLabel: 'Up to 10 people',
    featured: false,
    features: [
      'Community-style coaching',
      'High-signal group dynamics',
      'Session recordings included',
      'Weekly themed deep-dives',
      'Most affordable entry point',
    ],
    cta: 'Get Started',
  },
];
---

<Layout title="Pricing — Growth Room" description="Choose the Growth Room plan that fits your team. Weekly expert coaching sessions from €99/h.">

  <main class="min-h-screen flex flex-col items-center justify-start px-6 py-24 sm:py-32">

    <!-- Hero -->
    <div class="reveal text-center max-w-2xl">
      <p class="section-label">Pricing</p>
      <h1 class="mt-4 text-4xl font-black sm:text-5xl leading-tight" style="font-family: 'Montserrat', sans-serif;">
        Choose your<br />
        <span style="color: #c9a44a;">Growth Room</span>
      </h1>
      <p class="mt-5 text-base text-zinc-400 leading-relaxed">
        One expert-led session per week. Pick the format that suits your pace —<br class="hidden sm:block" />
        private focus or collaborative energy.
      </p>
    </div>

    <!-- Pricing grid -->
    <div class="reveal d1 mt-16 w-full max-w-5xl grid gap-6 lg:grid-cols-3">

      {plans.map((plan) => (
        <div class:list={[
          'relative flex flex-col rounded-2xl p-8',
          plan.featured ? 'glass-card-gold gold-ring' : 'glass-card',
        ]}>

          <!-- Most popular badge -->
          {plan.featured && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="premium-chip rounded-full px-4 py-1 text-[11px] font-bold uppercase tracking-widest" style="color: #c9a44a;">
                Most Popular
              </span>
            </div>
          )}

          <!-- Plan name -->
          <p class="text-sm font-bold uppercase tracking-widest" style="color: #c9a44a; font-family: 'Montserrat', sans-serif;">
            {plan.name}
          </p>

          <!-- Price -->
          <div class="mt-4 flex items-end gap-1.5">
            <span class="text-5xl font-black text-white leading-none" style="font-family: 'Montserrat', sans-serif;">
              {plan.price}
            </span>
            <span class="mb-1 text-lg text-zinc-400 font-medium">/h</span>
          </div>

          <p class="mt-1.5 text-sm text-zinc-500">1 hour per week included</p>

          <!-- Group badge -->
          <div class="mt-4 inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 self-start">
            <span class="text-zinc-400" set:html={iconUsers} />
            <span class="text-xs font-semibold text-zinc-300">{plan.groupLabel}</span>
          </div>

          <!-- Divider -->
          <div class="mt-6 divider-gold"></div>

          <!-- Features -->
          <ul class="mt-6 space-y-3.5 flex-1">
            {plan.features.map((feat) => (
              <li class="flex items-start gap-3 text-sm text-zinc-300">
                <span class="mt-0.5 shrink-0" style="color: #c9a44a;" set:html={iconCheck} />
                {feat}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <div class="mt-8">
            {plan.featured ? (
              <a href="#" class="btn-gold w-full text-center text-sm">
                {plan.cta}
              </a>
            ) : (
              <a
                href="#"
                class="outline-btn block w-full rounded-md border px-8 py-3.5 text-center text-sm font-bold transition-all"
              >
                {plan.cta}
              </a>
            )}
          </div>

        </div>
      ))}

    </div>

    <!-- Reassurance -->
    <p class="reveal d2 mt-10 text-sm text-zinc-500 text-center">
      All plans billed per session. No long-term commitment required.
    </p>

  </main>

</Layout>
