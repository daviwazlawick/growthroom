---
const CHECKOUT_URL = "https://alfima.com/daviwazl/ads-blueprint/purchase";
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ads Blueprint — Learn to Run Ads Yourself</title>

