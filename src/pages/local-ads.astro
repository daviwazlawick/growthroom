<div id="sp-widget" aria-live="polite" aria-atomic="true" role="status">
  <div class="sp-body">
    <div class="sp-avatar" id="sp-av"></div>
    <div class="sp-copy">
      <div class="sp-name"  id="sp-name"></div>
      <div class="sp-action" id="sp-action"></div>
      <div class="sp-meta"  id="sp-meta"></div>
    </div>
    <button class="sp-close" id="sp-close" aria-label="Close">✕</button>
  </div>
  <div class="sp-track"><div class="sp-bar" id="sp-bar"></div></div>
</div>

<script>
(function () {
  var names   = ['James T.','Sarah K.','Michael B.','Emily R.','David L.','Jessica M.','Chris W.','Amanda H.'];
  var actions = ['just purchased','just signed up for','just upgraded to'];
  var cities  = ['New York 🇺🇸','Los Angeles 🇺🇸','London 🇬🇧','Toronto 🇨🇦','Sydney 🇦🇺','Berlin 🇩🇪'];
  var times   = ['just now','2 min ago','4 min ago','9 min ago','14 min ago','22 min ago'];
  var colors  = ['#F5A623','#4A7FD4','#7B68EE','#2DB5A3','#E8697A','#5ABF8A'];
  var product = 'Launch Ads Blueprint';

  var w      = document.getElementById('sp-widget');
  var avEl   = document.getElementById('sp-av');
  var nameEl = document.getElementById('sp-name');
  var actEl  = document.getElementById('sp-action');
  var metaEl = document.getElementById('sp-meta');
  var barEl  = document.getElementById('sp-bar');
  var closeBtn = document.getElementById('sp-close');

  var VISIBLE = 5000;
  var CYCLE   = 7000;
  var visible = false;
  var autoHide = null;

  function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

  function show() {
    var name  = pick(names);
    var color = pick(colors);

    avEl.textContent        = name[0];
    avEl.style.background   = color;
    nameEl.textContent      = name;
    actEl.innerHTML         = pick(actions) + ' <strong>' + product + '</strong>';
    metaEl.textContent      = pick(times) + ' · ' + pick(cities);
    barEl.style.background  = color;

    // reset bar without transition, then animate
    barEl.style.transition  = 'none';
    barEl.style.width       = '100%';

    w.classList.remove('sp-out');
    // force reflow so transition fires
    void w.offsetWidth;
    w.classList.add('sp-in');
    visible = true;

    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        barEl.style.transition = 'width ' + VISIBLE + 'ms linear';
        barEl.style.width = '0%';
      });
    });

    autoHide = setTimeout(hide, VISIBLE);
  }

  function hide() {
    if (!visible) return;
    clearTimeout(autoHide);
    w.classList.remove('sp-in');
    w.classList.add('sp-out');
    visible = false;
  }

  closeBtn.addEventListener('click', hide);

  // start 3 s after load; cycle every 7 s
  setTimeout(function () {
    show();
    setInterval(function () {
      hide();
      setTimeout(show, 420);
    }, CYCLE);
  }, 3000);
}());
</script>

