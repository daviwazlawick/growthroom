<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #F7F5F2;
    --white:    #FFFFFF;
    --ink:      #1A1A1A;
    --ink2:     #333333;
    --ink3:     #555555;
    --muted:    #888888;
    --faint:    #AAAAAA;
    --border:   #E0DDD8;
    --border2:  #EEECEA;
    --tag-bg:   #EDEBE7;
    --accent:      #F5A623;
    --accent-dark: #D4880A;
    --accent-soft: #FFF4E0;
  }

  html, body { overflow-x: hidden; max-width: 100%; }
  html { font-family: 'DM Sans', system-ui, sans-serif; font-size: 16px; -webkit-font-smoothing: antialiased; background: var(--bg); color: var(--ink); }

  a { color: inherit; text-decoration: none; }

  /* ── Layout ── */
  .wrap { max-width: 760px; margin: 0 auto; padding: 0 24px; }
  section { border-bottom: 1px solid var(--border); }
  .s-white { background: var(--white); }
  .s-bg    { background: var(--bg); }

  /* ── Type scale ── */
  .eyebrow { font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--accent-dark); font-weight: 600; display: block; margin-bottom: 14px; }
  .h1 { font-size: clamp(30px, 5vw, 50px); font-weight: 600; line-height: 1.12; letter-spacing: -.02em; color: var(--ink); margin-bottom: 20px; overflow-wrap: break-word; }
  .h2 { font-size: clamp(24px, 4vw, 38px); font-weight: 600; line-height: 1.15; letter-spacing: -.018em; color: var(--ink); margin-bottom: 28px; overflow-wrap: break-word; }
  .lead { font-size: 18px; color: var(--ink3); line-height: 1.6; margin-bottom: 12px; }
  .body { font-size: 15px; color: var(--ink3); line-height: 1.7; }
  .small { font-size: 13px; color: var(--ink3); line-height: 1.6; }
  .tiny  { font-size: 11px; color: var(--muted); }
  .mono  { font-family: 'DM Mono', monospace; }

  /* ── Buttons ── */
  .btn {
    display: inline-block;
    background: var(--accent);
    color: #1A1A1A;
    padding: 14px 28px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: .03em;
    cursor: pointer;
    transition: background .15s, transform .1s;
    border: none;
    box-shadow: 0 6px 18px -8px rgba(245,166,35,.6);
  }
  .btn:hover { background: var(--accent-dark); transform: translateY(-1px); }
  .btn-sm { padding: 11px 22px; font-size: 13px; }

  /* ── Emphasis ── */
  .prose em, .body em, .lead em { color: var(--accent-dark); font-style: italic; font-weight: 500; }

  /* ── Video embed ── */
  .video-frame { position: relative; width: 100%; aspect-ratio: 16 / 9; border: 1px solid var(--border); background: #000; overflow: hidden; }
  .video-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .video-cap { font-size: 12px; color: var(--muted); margin-top: 12px; }

  /* ── Inline figures ── */
  .figure { margin: 28px 0 0; }
  .figure img { width: 100%; display: block; border: 1px solid var(--border); }
  .figure figcaption { font-size: 12px; color: var(--muted); margin-top: 10px; }
  /* portrait/tall images — keep them small and centered */
  .figure-portrait { max-width: 360px; margin-left: auto; margin-right: auto; }
  .figure-portrait figcaption { text-align: center; }
  .bio-photo { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border: 1px solid var(--border); display: block; }

  /* ── Price tag ── */
  .price-tag {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--accent); color: #1A1A1A;
    font-size: 11px; font-weight: 600; letter-spacing: .08em;
    text-transform: uppercase; padding: 6px 14px;
    margin-bottom: 28px;
  }
  .price-tag s { color: #8a5a08; text-decoration-color: #8a5a08; }

  /* ── Stats strip ── */
  .stats { display: flex; flex-wrap: wrap; gap: 32px; padding-top: 36px; margin-top: 36px; border-top: 1px solid var(--border); }
  .stat-val { font-size: 24px; font-weight: 600; color: var(--ink); display: block; }
  .stat-lbl { font-size: 12px; color: var(--muted); margin-top: 2px; display: block; }

  /* ── Divider rows ── */
  .divide > * + * { border-top: 1px solid var(--border2); }

  /* ── Pain rows ── */
  .pain-row { display: grid; grid-template-columns: 160px 1fr; gap: 16px; padding: 24px 0; align-items: start; }
  @media (max-width: 600px) { .pain-row { grid-template-columns: 1fr; gap: 6px; } }
  .pain-label { font-size: 11px; letter-spacing: .07em; text-transform: uppercase; color: var(--accent-dark); font-weight: 600; padding-top: 2px; }
  .pain-body { font-size: 15px; color: var(--ink2); line-height: 1.65; }
  .pain-note { font-size: 13px; color: var(--muted); font-style: italic; margin-top: 6px; }

  /* ── Dark callout ── */
  .callout-dark { background: var(--ink); color: var(--bg); padding: 28px 32px; margin: 28px 0; }
  .callout-dark { border-left: 4px solid var(--accent); }
  .callout-dark p { font-size: 16px; line-height: 1.6; }
  .callout-dark span { color: var(--accent); font-weight: 500; }

  /* ── Timeline ── */
  .timeline { border: 1px solid var(--border); }
  .tl-head { display: grid; grid-template-columns: 100px 1fr 1fr; gap: 12px; padding: 10px 20px; background: var(--bg); border-bottom: 1px solid var(--border2); }
  .tl-head span { font-size: 11px; letter-spacing: .07em; text-transform: uppercase; color: var(--muted); font-weight: 500; }
  .tl-row { display: grid; grid-template-columns: 100px 1fr 1fr; gap: 12px; padding: 16px 20px; border-top: 1px solid var(--border2); align-items: start; }
  @media (max-width: 580px) {
    .tl-head { grid-template-columns: 1fr 1fr; }
    .tl-head span:nth-child(2) { display: none; }
    .tl-row { grid-template-columns: 80px 1fr; }
    .tl-row .tl-detail { display: none; }
  }
  .tl-period { font-size: 13px; font-weight: 600; color: var(--ink); }
  .tl-detail { font-size: 13px; color: var(--muted); }
  .tl-result { font-size: 13px; font-weight: 600; color: var(--accent-dark); }

  /* ── Case grid ── */
  .case-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 8px; margin-top: 24px; }
  .case-card { background: var(--bg); border: 1px solid var(--border); padding: 14px 16px; }
  .case-biz  { font-size: 13px; font-weight: 500; color: var(--ink); }
  .case-city { font-size: 11px; color: var(--muted); margin-top: 2px; }

  /* ── Three column grid ── */
  .three-col { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border2); border: 1px solid var(--border2); margin-top: 28px; }
  @media (max-width: 640px) { .three-col { grid-template-columns: 1fr; } }
  .three-col-cell { background: var(--white); padding: 24px 22px; }
  .cell-head { font-size: 11px; font-weight: 500; letter-spacing: .07em; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
  .cell-body { font-size: 13px; color: var(--ink2); line-height: 1.65; }

  /* ── Bio layout ── */
  .bio-grid { display: grid; grid-template-columns: 1fr 260px; gap: 40px; align-items: start; }
  @media (max-width: 640px) { .bio-grid { grid-template-columns: 1fr; } }
  .bio-sidebar > * + * { margin-top: 10px; }
  .sidebar-card { border: 1px solid var(--border); background: var(--bg); padding: 20px; }
  .sidebar-dark { background: var(--ink); color: var(--bg); padding: 20px; }
  .sidebar-dark .cell-head { color: #BCBAB5; }
  .sidebar-dark .cell-body { color: #D0CEC9; font-size: 13px; line-height: 1.65; font-style: italic; }
  .cred-list { list-style: none; }
  .cred-list li { display: flex; gap: 8px; font-size: 13px; color: var(--ink2); padding: 4px 0; }
  .cred-list li::before { content: '—'; color: var(--muted); flex-shrink: 0; }

  /* ── Checklist ── */
  .checklist { border: 1px solid var(--border); background: var(--white); }
  .check-item { display: flex; gap: 16px; align-items: flex-start; padding: 14px 20px; border-top: 1px solid var(--border2); }
  .check-item:first-child { border-top: none; }
  .check-icon { flex-shrink: 0; margin-top: 2px; }
  .check-icon svg { width: 16px; height: 16px; stroke: var(--accent-dark); }
  .check-text { font-size: 14px; color: var(--ink2); line-height: 1.55; }

  /* ── Module grid ── */
  .module-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border2); border: 1px solid var(--border2); }
  @media (max-width: 580px) { .module-grid { grid-template-columns: 1fr; } }
  .module-cell { background: var(--white); padding: 22px 24px; }
  .mod-num { font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 500; color: var(--accent-dark); margin-bottom: 10px; }
  .mod-title { font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 6px; }
  .mod-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }

  /* ── Bonus items ── */
  .bonus-list > * + * { margin-top: 8px; }
  .bonus-item { display: flex; gap: 16px; align-items: flex-start; background: var(--bg); border: 1px solid var(--border); padding: 18px 20px; }
  .bonus-body { flex: 1; }
  .bonus-title { font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 4px; }
  .bonus-desc { font-size: 13px; color: var(--muted); line-height: 1.55; }
  .bonus-val { text-align: right; flex-shrink: 0; }
  .bonus-val .tiny { display: block; }
  .bonus-val strong { font-size: 14px; font-weight: 600; color: var(--accent-dark); }

  /* ── Pricing ── */
  .pricing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; align-items: start; }
  @media (max-width: 620px) { .pricing-grid { grid-template-columns: 1fr; } }
  .value-table { border: 1px solid var(--border); background: var(--white); }
  .value-table-head { padding: 14px 20px; border-bottom: 1px solid var(--border2); }
  .value-row { display: flex; justify-content: space-between; align-items: center; padding: 13px 20px; border-top: 1px solid var(--border2); font-size: 13px; }
  .value-row:first-child { border-top: none; }
  .value-row.total { background: var(--bg); font-weight: 600; }
  .value-row span:last-child { color: var(--muted); }
  .value-row.total span:last-child { color: var(--ink); font-weight: 600; }

  .cta-block { background: var(--ink); color: var(--bg); padding: 28px; border-top: 3px solid var(--accent); }
  .cta-price-row { display: flex; align-items: baseline; gap: 12px; margin: 10px 0 6px; }
  .cta-price { font-size: 52px; font-weight: 600; line-height: 1; color: var(--accent); }
  .cta-was { font-size: 18px; color: #777; text-decoration: line-through; text-decoration-color: #666; }
  .cta-sub { font-size: 13px; color: #BCBAB5; margin-bottom: 24px; }
  .btn-light { display: block; width: 100%; background: var(--bg); color: var(--ink); padding: 15px; font-size: 14px; font-weight: 600; letter-spacing: .02em; text-align: center; text-decoration: none; cursor: pointer; transition: background .15s; border: none; }
  .btn-light:hover { background: #fff; }
  .cta-note { font-size: 11px; color: #888; text-align: center; margin-top: 10px; }

  .guarantee { border: 1px solid var(--border); border-left: 4px solid var(--accent); background: var(--white); padding: 20px; margin-top: 10px; }
  .guarantee .cell-head { margin-bottom: 8px; }

  /* ── Business tags ── */
  .biz-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px; }
  .biz-tag { font-size: 12px; color: var(--ink3); border: 1px solid var(--border); background: var(--white); padding: 5px 12px; }

  /* ── Section padding ── */
  .pad { padding: 64px 0; }
  @media (max-width: 600px) { .pad { padding: 48px 0; } }

  /* ── Body copy spacing ── */
  .prose > * + * { margin-top: 18px; }

  /* ── Mobile breathing room ── */
  @media (max-width: 600px) {
    .wrap { padding: 0 22px; }
    .h1 br, .h2 br, .lead br { display: none; }
    .callout-dark { padding: 22px 22px; }
    .cta-block, .cta-price { word-break: break-word; }
    .cta-price { font-size: 46px; }
  }
</style>
</head>
<body>

<!-- HERO -->
<section class="s-bg" style="background:linear-gradient(170deg,#FFF1DA 0%,#FBF0E0 30%,var(--bg) 75%);">
  <div class="wrap pad">
    <div class="price-tag">Special offer — €27 &nbsp;<s>€197</s></div>
    <h1 class="h1">Stop paying someone to do<br>what you can learn in a weekend.</h1>
    <p class="lead">The complete blueprint for creating ads and running them yourself — from your very first campaign to your first real results.</p>
    <div style="margin: 36px -24px 36px;">
      <img src="/img/launch-ads-mockup.png" alt="Launch Ads Blueprint — product mockup" style="width:100%; display:block;" />
    </div>
    <p class="body" style="max-width:520px; margin-bottom:36px;">No agency. No freelancer. No guessing. Just a clear, step-by-step system anyone can follow.</p>
    <p class="tiny" style="max-width:520px; margin-top:-20px; margin-bottom:36px; color:var(--muted);">Built by someone who managed millions in ad spend at venture-backed startups — distilled into a system simple enough for a total beginner.</p>

    <a href="#pricing" class="btn">Give me the whole blueprint →</a>
    <p class="tiny" style="margin-top:14px;">One-time payment · Instant access · 30-day guarantee</p>
  </div>
</section>


<!-- SALES VIDEO -->
<section class="s-white">
  <div class="wrap pad">
    <span class="eyebrow">Watch first — 4 minutes</span>
    <h2 class="h2" style="margin-bottom:24px;">Why most beginners never launch<br>their first ad — and how to fix it.</h2>
    <div class="video-frame">
      <iframe
        src="https://www.youtube.com/embed/pqgiUcjp8Zw?controls=0&rel=0&modestbranding=1&showinfo=0&playsinline=1&iv_load_policy=3"
        title="Launch Ads Blueprint"
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen></iframe>
    </div>
    <p class="video-cap">Davi walks you through exactly what's inside and why the setup — not the platform — is what makes beginners fail.</p>
    <div style="margin-top:24px;">
      <a href="#pricing" class="btn btn-sm">Get instant access — €27 →</a>
    </div>
  </div>
</section>


<!-- PAIN -->
<section class="s-bg">
  <div class="wrap pad">
    <span class="eyebrow">Sound familiar?</span>
    <h2 class="h2">Does this sound like you?</h2>

    <div class="divide">

      <div class="pain-row">
        <span class="pain-label">The dependency trap</span>
        <div>
          <p class="pain-body">Every time you need an ad, you wait on someone else. A freelancer, an agency, "a friend who knows this stuff." You're never in control of your own marketing.</p>
          <p class="pain-note">And you pay for it every single time.</p>
        </div>
      </div>

      <div class="pain-row">
        <span class="pain-label">The intimidating dashboard</span>
        <div>
          <p class="pain-body">You opened Ads Manager once. There were 14 menus, 6 campaign objectives, and a budget field you were afraid to touch. You closed the tab.</p>
          <p class="pain-note">Later never came.</p>
        </div>
      </div>

      <div class="pain-row">
        <span class="pain-label">The useless boost</span>
        <div>
          <p class="pain-body">You hit "Boost Post," spent €50, got 200 likes from people who'll never buy anything — and not a single real result.</p>
          <p class="pain-note">That wasn't an ad. That was a donation to Meta.</p>
        </div>
      </div>

      <div class="pain-row">
        <span class="pain-label">Fear of burning money</span>
        <div>
          <p class="pain-body">You've heard the stories. "I spent €300 and got nothing." The idea of watching your budget drain with no results keeps you from even starting.</p>
        </div>
      </div>

      <div class="pain-row">
        <span class="pain-label">Tutorials that go nowhere</span>
        <div>
          <p class="pain-body">You've watched hours of YouTube. Saved a dozen "how to run ads" videos. And you still can't sit down and launch a campaign on your own — because nobody showed you the full sequence, start to finish.</p>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- AGITATION -->
<section class="s-white">
  <div class="wrap pad">
    <span class="eyebrow">The real problem</span>
    <h2 class="h2">The platform isn't the problem.<br>The setup is.</h2>

    <div class="prose" style="max-width:620px;">
      <p class="body">Open Ads Manager and you're hit with campaigns, ad sets, the pixel, audiences, budgets, objectives — a thousand buttons, and the feeling that one wrong click burns your money.</p>
      <p class="body">So you go to YouTube to learn. One video says use traffic campaigns. The next says engagement is better. One says target interests, another says go broad. After a few hours you're <em>more</em> confused than when you started — and not confident enough to launch.</p>
      <p class="body">So you delay. You overthink it. Or you give up and pay an agency hundreds — sometimes thousands — to set things up for you, before you've even spent a cent on ads.</p>
    </div>

    <div class="callout-dark" style="max-width:620px;">
      <p>Beginners don't fail because they're not smart. <span>They fail because nobody showed them the setup, in the right order.</span></p>
    </div>

    <p class="body" style="max-width:620px;">That's exactly why I built the Launch Ads Blueprint: a practical, step-by-step path that shows you what to do, where to click, and how to launch — without the theory, the jargon, or the guessing.</p>
  </div>
</section>


<!-- PROOF -->
<section class="s-bg">
  <div class="wrap pad">
    <span class="eyebrow">Real results</span>
    <h2 class="h2">A complete beginner.<br>Their first campaign ever.</h2>
    <p class="body" style="color:var(--muted); margin-bottom:28px;">Starting budget: €8/day. Never touched Ads Manager before. No agency.</p>

    <div class="timeline">
      <div class="tl-head">
        <span>Period</span>
        <span>What changed</span>
        <span>Result</span>
      </div>
      <div class="tl-row">
        <span class="tl-period">Day 1</span>
        <span class="tl-detail">Followed the setup: account, pixel, domain verified</span>
        <span class="tl-result">First campaign live</span>
      </div>
      <div class="tl-row">
        <span class="tl-period">Week 1</span>
        <span class="tl-detail">Right objective · €8/day · 3 ads tested</span>
        <span class="tl-result">4 real leads</span>
      </div>
      <div class="tl-row">
        <span class="tl-period">Week 2</span>
        <span class="tl-detail">Read the numbers, killed the loser, scaled the winner</span>
        <span class="tl-result">11 leads · €6.80 each</span>
      </div>
      <div class="tl-row">
        <span class="tl-period">Week 3</span>
        <span class="tl-detail">Same setup, zero hand-holding</span>
        <span class="tl-result">18 leads · running it solo</span>
      </div>
    </div>

    <p class="body" style="margin-top:28px; margin-bottom:18px; max-width:560px;">The point isn't the numbers. It's that someone who had never launched an ad did it themselves — and never needed to hire anyone.</p>

    <div class="case-grid">
      <div class="case-card"><p class="case-biz">Set up the account</p><p class="case-city">Business Manager + pixel</p></div>
      <div class="case-card"><p class="case-biz">Picked the objective</p><p class="case-city">The right one, on purpose</p></div>
      <div class="case-card"><p class="case-biz">Built the first ad</p><p class="case-city">Image &amp; video</p></div>
      <div class="case-card"><p class="case-biz">Read the metrics</p><p class="case-city">Knew what to do next</p></div>
    </div>

    <div style="margin-top:32px;">
      <a href="#pricing" class="btn btn-sm">I want to launch mine →</a>
    </div>
  </div>
</section>


<!-- MARKET SHIFT -->
<section class="s-white">
  <div class="wrap pad">
    <span class="eyebrow">The shift</span>
    <h2 class="h2">You don't need a specialist<br>anymore. You need the steps.</h2>

    <div class="prose" style="max-width:620px;">
      <p class="body">Hiring someone to set up your Meta Ads account correctly costs €400, €500, €1,000 or more — before you've spent a single euro on ads.</p>
      <p class="body">Meanwhile, Meta has made self-managed ads more powerful than ever. AI-assisted targeting. Automated testing. Smart bidding that optimises while you sleep — <em>if</em> your setup and tracking are right.</p>
      <p class="body">The tools used to require a specialist. They don't anymore. The only thing standing between you and a live campaign is knowing the exact sequence.</p>
    </div>

    <div class="three-col">
      <div class="three-col-cell">
        <p class="cell-head">What it used to take</p>
        <p class="cell-body">A certified specialist, a paid setup fee of €400–1,000+, and weeks of waiting.</p>
      </div>
      <div class="three-col-cell">
        <p class="cell-head">What it takes now</p>
