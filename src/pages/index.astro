---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Solution from '../components/Solution.astro';
import ValueStack from '../components/ValueStack.astro';
import Benefits from '../components/Benefits.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WaitlistCta from '../components/WaitlistCta.astro';

const waitlistUrl = "#waitlist";
---

<Layout
	title="Growth Room | Weekly Expert Access"
	description="Fix what is broken in your paid acquisition, recover wasted spend, and scale what works."
>
	<Hero waitlistUrl={waitlistUrl} />
	<Problem />
	<Solution />
	<ValueStack />
	<Benefits />
	<HowItWorks />
	<div id="waitlist">
		<WaitlistCta waitlistUrl={waitlistUrl} />
	</div>
</Layout>
