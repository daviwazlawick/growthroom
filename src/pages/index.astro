---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="coming-soon">
		<p class="eyebrow">growthroom.eu</p>
		<h1>Coming Soon</h1>
		<p class="description">
			Estamos preparando algo novo. Em breve, o site estara no ar.
		</p>
	</main>
</Layout>

<style>
	.coming-soon {
		min-height: 100vh;
		display: grid;
		place-content: center;
		padding: 2rem;
		text-align: center;
		background: radial-gradient(circle at top, #1d2535 0%, #0e1118 60%, #080a0f 100%);
		color: #f7f8fa;
		font-family:
			Inter,
			system-ui,
			-apple-system,
			Segoe UI,
			Roboto,
			sans-serif;
	}

	.eyebrow {
		margin: 0;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		font-size: 0.78rem;
		color: #a7b3c9;
	}

	h1 {
		margin: 0.75rem 0 0.5rem;
		font-size: clamp(2.2rem, 6vw, 4rem);
		line-height: 1.05;
	}

	.description {
		margin: 0;
		font-size: clamp(1rem, 2.3vw, 1.25rem);
		color: #d0d7e5;
		max-width: 32ch;
	}
</style>
