        <div class="fc-lesson locked"><span class="num">09</span> Meta Ads campaign goals explained <span class="fc-tag">🔒</span></div>
        <div class="fc-lesson locked"><span class="num">10</span> Setting up a Meta lead campaign ad set <span class="fc-tag">🔒</span></div>
        <div class="fc-lesson locked"><span class="num">11</span> Setting up a Meta lead campaign ad set — part 2 <span class="fc-tag">🔒</span></div>
        <div class="fc-lesson locked"><span class="num">12</span> Master Facebook Ads audiences and targeting <span class="fc-tag">🔒</span></div>
        <div class="fc-lesson locked"><span class="num">13</span> Meta Advantage+ targeting controls explained <span class="fc-tag">🔒</span></div>
        <div class="fc-lesson locked"><span class="num">14</span> Facebook Ads setup: excluding key countries <span class="fc-tag">🔒</span></div>
        <div class="fc-lesson locked"><span class="num">15</span> Building your first ad: image <span class="fc-tag">🔒</span></div>
        <div class="fc-lesson locked"><span class="num">16</span> Building your first ad: video <span class="fc-tag">🔒</span></div>
        <div class="fc-lesson locked"><span class="num">17</span> Final review before you hit publish <span class="fc-tag">🔒</span></div>
        <div class="fc-lesson locked"><span class="num">18</span> Wrapping up ads with some tips <span class="fc-tag">🔒</span></div>
        <div class="fc-lesson locked"><span class="num">19</span> Setting up events from Meta to optimise <span class="fc-tag">🔒</span></div>
        <div class="fc-lesson locked"><span class="num">20</span> Testing the event and final class <span class="fc-tag">🔒</span></div>
        <div class="fc-lock-note" id="fc-lock-note">
          <p id="fc-lock-text"></p>
          <a href={CHECKOUT_URL} target="_blank" rel="noopener" class="btn-dark" style="display:flex; width:100%;">Unlock the full course — €27 →</a>
        </div>
      </div>
      <div class="fc-offer" id="fc-offer">
        <p class="tiny" style="color:#A1A1AA; letter-spacing:.08em; text-transform:uppercase; font-weight:600;">Ready for lesson 3?</p>
        <div class="price-row" style="margin:8px 0 4px;">
          <span class="price-big" style="font-size:40px; color:#fff;">€27</span>
          <span class="price-was" style="font-size:16px;">€197</span>
        </div>
        <p class="small" style="color:#D4D4D8; margin-bottom:8px;">Next up: tracking. Installing your pixel is the step that decides whether Meta can optimise your ads at all — and it's where most beginners give up. I walk you through it click by click.</p>
        <p class="small" style="color:#D4D4D8; margin-bottom:18px;">One-time payment · Unlocks all 18 remaining lessons + bonuses, ready to watch on the Alfima platform.</p>
        <a href={CHECKOUT_URL} target="_blank" rel="noopener" class="btn-light">Next lesson → Buy &amp; keep watching on Alfima</a>
        <p class="tiny" style="text-align:center; margin-top:10px; color:#A1A1AA;">Secure checkout via Alfima · Card &amp; PayPal · Instant access · 30-day money-back guarantee</p>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  var UNLOCK_KEY = "gr_free_class_v1";

  var overlay    = document.getElementById("fc-overlay");
  var formState  = document.getElementById("fc-form-state");
  var videoState = document.getElementById("fc-video-state");
  var form       = document.getElementById("fc-form");
  var submitBtn  = document.getElementById("fc-submit");
  var errorEl    = document.getElementById("fc-error");
  var player     = document.getElementById("fc-player");

  async function sha256(value) {
    var normalized = (value || "").toLowerCase().trim();
    if (!normalized) return "";
    var buffer = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(normalized));
    return Array.from(new Uint8Array(buffer)).map(function (b) { return b.toString(16).padStart(2, "0"); }).join("");
  }
  function getCookie(name) {
    var m = document.cookie.match("(^|;)\\s*" + name + "\\s*=\\s*([^;]+)");
    return m ? m.pop() : "";
  }
  function getFbc() {
    var fbc = getCookie("_fbc");
    if (fbc) return fbc;
    var m = window.location.search.match(/[?&]fbclid=([^&]+)/);
    return m ? "fb.1." + Date.now() + "." + decodeURIComponent(m[1]) : "";
  }
  function getUrlParams() {
    var params = {};
    new URLSearchParams(window.location.search).forEach(function (v, k) { if (v) params[k] = v; });
    return params;
  }

  function isUnlocked() {
    try { return !!localStorage.getItem(UNLOCK_KEY); } catch (e) { return false; }
  }
  function renderState() {
    var unlocked = isUnlocked();
    formState.style.display  = unlocked ? "none" : "block";
    videoState.style.display = unlocked ? "block" : "none";
  }
  function openModal() {
    renderState();
    overlay.classList.add("open");
    document.body.style.overflow = "hidden";
  }
  function closeModal() {
    overlay.classList.remove("open");
    document.body.style.overflow = "";
    if (player) player.pause();
  }

  var triggers = document.querySelectorAll("[data-free-class]");
  for (var i = 0; i < triggers.length; i++) {
    triggers[i].addEventListener("click", function (e) { e.preventDefault(); openModal(); });
  }
  document.getElementById("fc-close").addEventListener("click", closeModal);
  overlay.addEventListener("click", function (e) { if (e.target === overlay) closeModal(); });
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape" && overlay.classList.contains("open")) closeModal();
  });

  form.addEventListener("submit", async function (e) {
    e.preventDefault();
    var fullName = document.getElementById("fc-name").value.trim();
    var email    = document.getElementById("fc-email").value.trim().toLowerCase();

    if (!fullName || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errorEl.textContent = "Please enter your name and a valid email.";
      errorEl.style.display = "block";
      return;
    }
    errorEl.style.display = "none";
    submitBtn.disabled = true;
    var originalLabel = submitBtn.textContent;
    submitBtn.textContent = "Opening…";

    var nameParts = fullName.split(/\s+/);
    var eventId   = Date.now() + "_" + Math.floor(Math.random() * 1e15);
    var emHash = await sha256(email);
    var fnHash = await sha256(nameParts[0]);
    var lnHash = await sha256(nameParts.slice(1).join(" "));
    var fbp = getCookie("_fbp");
    var fbc = getFbc();

    try {
      var res = await fetch("/api/leads", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          leadType: "free_class",
          product:  "launch-ads-blueprint",
          fullName: fullName,
          email:    email,
          meta_event_id:         eventId,
          meta_em:               emHash,
          meta_fn:               fnHash,
          meta_ln:               lnHash,
          meta_fbp:              fbp,
          meta_fbc:              fbc,
          meta_user_agent:       navigator.userAgent,
          meta_event_source_url: window.location.href,
          submitted_at:          new Date().toISOString(),
          marketing_consent:     !!window.__marketingConsent,
          url_params:            getUrlParams(),
        }),
      });
      if (!res.ok) throw new Error("bad status");

      try { localStorage.setItem(UNLOCK_KEY, JSON.stringify({ email: email, at: new Date().toISOString() })); } catch (err) {}

      if (typeof window.trackMarketing === "function") {
        window.trackMarketing("Lead", { content_name: "Free Lesson 1", content_category: "free_class" }, { eventID: eventId });
      }
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "free_class_lead",
        event_id: eventId,
        em: emHash, fn: fnHash, ln: lnHash,
        fbp: fbp, fbc: fbc,
      });

      renderState();
      if (player && player.play) player.play().catch(function () {});
    } catch (err) {
      errorEl.textContent = "Something went wrong. Please try again.";
      errorEl.style.display = "block";
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalLabel;
    }
  });

  // ── Free lessons: player com aulas 1 e 2 ────────────────────────────
  var LESSONS = [
    { label: "Lesson 1 of 20 — open preview", title: "Why most beginners fail.",        src: "/videos/lesson-1.mp4" },
    { label: "Lesson 2 of 20 — open preview", title: "Who the Meta Ads course is for.", src: "/videos/lesson-2.mp4" },
  ];
  var currentLesson = 0;
  var milestones = { 25: false, 50: false, 75: false, 95: false };

  function playLesson(i, autoplay) {
    currentLesson = i;
    milestones = { 25: false, 50: false, 75: false, 95: false };
    document.getElementById("fc-eyebrow").textContent = LESSONS[i].label;
    document.getElementById("fc-lesson-title").textContent = LESSONS[i].title;
    var nextCta = document.getElementById("fc-next-cta");
    if (nextCta) {
      nextCta.dataset.mode = i === 0 ? "free" : "paid";
      nextCta.textContent = i === 0
        ? "Next lesson → Watch lesson 2 (still free)"
        : "Next lesson → Buy & keep watching — €27";
    }
    var rows = document.querySelectorAll(".fc-lesson.fc-playable");
    for (var r = 0; r < rows.length; r++) {
      var active = Number(rows[r].dataset.lesson) === i;
      rows[r].classList.toggle("active", active);
      rows[r].querySelector(".fc-tag").textContent = active ? "▶ Watching now" : "▶ Watch free";
    }
    if (player.getAttribute("src") !== LESSONS[i].src) player.setAttribute("src", LESSONS[i].src);
    if (autoplay && player.play) player.play().catch(function () {});
  }

  document.querySelectorAll(".fc-lesson.fc-playable").forEach(function (row) {
    row.addEventListener("click", function () { playLesson(Number(row.dataset.lesson), true); });
  });

  var nextCtaEl = document.getElementById("fc-next-cta");
  if (nextCtaEl) {
    nextCtaEl.addEventListener("click", function (e) {
      if (nextCtaEl.dataset.mode === "free") { e.preventDefault(); playLesson(1, true); }
    });
  }

  // ── Aulas bloqueadas: clique mostra aviso + CTA de compra ────────────
  var lockNote = document.getElementById("fc-lock-note");
  document.querySelectorAll(".fc-lesson.locked").forEach(function (row) {
    row.addEventListener("click", function () {
      var num = row.querySelector(".num").textContent;
      var title = Array.prototype.filter
        .call(row.childNodes, function (n) { return n.nodeType === 3; })
        .map(function (n) { return n.textContent; }).join("").trim();
      document.getElementById("fc-lock-text").innerHTML =
        "Lesson " + num + " — <strong>" + title + "</strong> — is part of the full course. " +
        "Unlock all 18 remaining lessons + the bonuses for a one-time <strong>€27</strong> <s>€197</s>.";
      row.after(lockNote);
      lockNote.style.display = "block";
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: "free_class_locked_click", lesson: Number(num) });
    });
  });

  // ── Video progress → dataLayer (25/50/75/95%) ───────────────────────
  if (player) {
    player.addEventListener("ended", function () {
      if (currentLesson === 0) { playLesson(1, true); return; }
      var offer = document.getElementById("fc-offer");
      if (!offer) return;
      offer.scrollIntoView({ behavior: "smooth", block: "center" });
      offer.classList.add("fc-attn");
      setTimeout(function () { offer.classList.remove("fc-attn"); }, 4000);
    });
    player.addEventListener("timeupdate", function () {
      if (!player.duration) return;
      var pct = (player.currentTime / player.duration) * 100;
      for (var mark in milestones) {
        if (!milestones[mark] && pct >= Number(mark)) {
          milestones[mark] = true;
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: "free_class_progress", lesson: currentLesson + 1, video_percent: Number(mark) });
          if (mark === "50" && typeof window.trackMarketing === "function") {
            window.trackMarketing("ViewContent", { content_name: "Free Lesson " + (currentLesson + 1), content_category: "free_class" });
          }
        }
      }
    });
  }
})();
</script>

<!-- Cookie Banner -->
<div id="cookie-banner" style="position:fixed; left:16px; right:16px; bottom:16px; z-index:9999; display:none; max-width:560px; margin:0 auto; background:#fff; color:var(--body); border:1px solid var(--line); border-radius:14px; box-shadow:0 12px 40px rgba(0,0,0,.12); padding:18px 20px;">
  <p style="font-size:13px; line-height:1.5; margin-bottom:14px;">
    We use cookies to improve your experience and measure our marketing. See our
    <a href="/privacy-policy" style="color:var(--accent-ink); text-decoration:underline;">Privacy Policy</a>.
  </p>
  <div style="display:flex; gap:10px;">
    <button id="cookie-reject" type="button" style="flex:1; background:transparent; color:var(--body); border:1px solid var(--line); border-radius:8px; padding:10px; font-size:13px; font-weight:600; cursor:pointer; font-family:inherit;">Reject</button>
    <button id="cookie-accept" type="button" style="flex:1; background:var(--ink); color:#fff; border:none; border-radius:8px; padding:10px; font-size:13px; font-weight:600; cursor:pointer; font-family:inherit;">Accept</button>
  </div>
</div>
<script>
  (function () {
    var KEY = "gr_cookie_consent_v1";
    var banner = document.getElementById("cookie-banner");
    if (!banner) return;
    function hide() { banner.style.display = "none"; }
    function save(v) { try { localStorage.setItem(KEY, v); } catch (e) {} }
    var choice = null;
    try { choice = localStorage.getItem(KEY); } catch (e) {}
    if (!choice) {
      banner.style.display = "block";
    }
    document.getElementById("cookie-accept").addEventListener("click", function () {
      save("accepted");
      window.__marketingConsent = true;
      if (typeof gtag === "function") gtag('consent', 'update', { 'analytics_storage': 'granted' });
      hide();
    });
    document.getElementById("cookie-reject").addEventListener("click", function () {
      save("rejected");
      window.__marketingConsent = false;
      if (typeof gtag === "function") gtag('consent', 'update', { 'analytics_storage': 'denied' });
      hide();
    });
  })();
</script>
<!-- End Cookie Banner -->

<!-- Passa atribuição (fbclid, utm_*, _fbp, _fbc) para o checkout (cross-domain) -->
<script>
  (function () {
    function getCookie(name) {
      var m = document.cookie.match("(^|;)\\s*" + name + "\\s*=\\s*([^;]+)");
      return m ? m.pop() : "";
    }
    function buildCheckoutUrl(base) {
      try {
        var url = new URL(base, window.location.origin);
        var current = new URLSearchParams(window.location.search);
        current.forEach(function (value, key) { if (value) url.searchParams.set(key, value); });
        var fbp = getCookie("_fbp");
        var fbc = getCookie("_fbc");
        if (fbp) url.searchParams.set("fbp", fbp);
        if (fbc) {
          url.searchParams.set("fbc", fbc);
        } else if (current.get("fbclid")) {
          url.searchParams.set("fbc", "fb.1." + Date.now() + "." + current.get("fbclid"));
        }
        url.searchParams.set("consent", window.__marketingConsent ? "granted" : "denied");
        return url.toString();
      } catch (e) { return base; }
    }
    function refreshLinks() {
      var links = document.querySelectorAll("a[href*='alfima.com']");
      for (var i = 0; i < links.length; i++) {
        if (!links[i].dataset.base) links[i].dataset.base = links[i].getAttribute("href");
        links[i].setAttribute("href", buildCheckoutUrl(links[i].dataset.base));
      }
    }
    refreshLinks();
    document.addEventListener("click", function (e) {
      var a = e.target && e.target.closest ? e.target.closest("a[href*='alfima.com']") : null;
      if (a) a.setAttribute("href", buildCheckoutUrl(a.dataset.base || a.getAttribute("href")));
    }, true);
  })();
</script>
<!-- End attribution passthrough -->

