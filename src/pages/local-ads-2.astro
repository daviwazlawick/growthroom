<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:      #FFFFFF;
    --bg2:     #FAFAF9;
    --ink:     #18181B;
    --body:    #52525B;
    --muted:   #A1A1AA;
    --line:    #E4E4E7;
    --line2:   #F4F4F5;
    --accent:  #F59E0B;
    --accent-ink: #B45309;
    --accent-soft: #FFFBEB;
    --green:   #15803D;
  }

  html, body { overflow-x: hidden; max-width: 100%; }
  html {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    background: var(--bg);
    color: var(--ink);
    scroll-behavior: smooth;
  }
  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }

  /* ── Layout ── */
  .container { max-width: 1064px; margin: 0 auto; padding-left: 24px; padding-right: 24px; }
  .narrow { max-width: 640px; }
  .sec { padding-top: 104px; padding-bottom: 104px; }
  .sec-line { border-top: 1px solid var(--line); }
  .bg2 { background: var(--bg2); }
  @media (max-width: 640px) { .sec { padding-top: 72px; padding-bottom: 72px; } }

  /* ── Type ── */
  .kicker { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 600; letter-spacing: .02em; color: var(--accent-ink); background: var(--accent-soft); border: 1px solid #FDE68A; border-radius: 999px; padding: 6px 14px; margin-bottom: 24px; }
  .h1 { font-size: clamp(38px, 5.4vw, 62px); font-weight: 700; letter-spacing: -.035em; line-height: 1.05; margin-bottom: 24px; }
  .h2 { font-size: clamp(28px, 3.6vw, 40px); font-weight: 700; letter-spacing: -.028em; line-height: 1.12; margin-bottom: 18px; }
  .h3 { font-size: 17px; font-weight: 600; letter-spacing: -.01em; margin-bottom: 8px; }
  .sub { font-size: 19px; line-height: 1.65; color: var(--body); }
  .p { font-size: 16px; line-height: 1.7; color: var(--body); }
  .small { font-size: 14px; line-height: 1.6; color: var(--body); }
  .tiny { font-size: 12.5px; line-height: 1.55; color: var(--muted); }
  .sec-intro { max-width: 620px; margin-bottom: 56px; }
  .sec-intro .p { font-size: 17px; }

  /* ── Buttons ── */
  .btn-dark {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    background: var(--ink); color: #fff;
    font-size: 15px; font-weight: 600; letter-spacing: -.005em;
    padding: 15px 28px; border-radius: 10px; border: none; cursor: pointer;
    transition: transform .12s, box-shadow .15s, background .15s;
    box-shadow: 0 1px 2px rgba(0,0,0,.12);
    font-family: inherit;
  }
  .btn-dark:hover { background: #000; transform: translateY(-1px); box-shadow: 0 6px 16px -6px rgba(0,0,0,.35); }
  .btn-ghost {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    background: var(--bg); color: var(--ink);
    font-size: 15px; font-weight: 600;
    padding: 15px 28px; border-radius: 10px; border: 1px solid var(--line); cursor: pointer;
    transition: border-color .15s, background .15s, transform .12s;
    font-family: inherit;
  }
  .btn-ghost:hover { border-color: var(--ink); transform: translateY(-1px); }
  .cta-row { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
  @media (max-width: 640px) {
    .cta-row { flex-direction: column; align-items: stretch; }
    .btn-dark, .btn-ghost { width: 100%; }
  }

  /* ── Who this is for ── */
  .who { padding-top: 56px; padding-bottom: 64px; }
  .who-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .who-badge { font-size: 13.5px; font-weight: 500; color: var(--body); background: var(--bg); border: 1px solid var(--line); border-radius: 999px; padding: 8px 16px; }
  @media (max-width: 640px) { .who { padding-top: 44px; padding-bottom: 52px; } }

  /* ── Header ── */
  .topbar { border-bottom: 1px solid var(--line); background: rgba(255,255,255,.85); backdrop-filter: blur(8px); }
  .topbar-in { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .brand { font-size: 15px; font-weight: 700; letter-spacing: -.02em; display: flex; align-items: center; gap: 8px; }
  .brand-dot { width: 10px; height: 10px; border-radius: 3px; background: var(--accent); display: inline-block; }
  .topbar .btn-dark { padding: 9px 18px; font-size: 13.5px; border-radius: 8px; }

  /* ── Hero ── */
  .hero { padding-top: 96px; padding-bottom: 88px; }
  @media (max-width: 640px) { .hero { padding-top: 64px; padding-bottom: 56px; } }
  .hero-sub { max-width: 600px; margin-bottom: 36px; }
  .hero-trust { display: flex; gap: 20px; flex-wrap: wrap; margin-top: 20px; }
  .hero-trust span { font-size: 13px; color: var(--muted); display: inline-flex; align-items: center; gap: 6px; }
  .hero-shot { margin-top: 64px; border: 1px solid var(--line); border-radius: 16px; overflow: hidden; box-shadow: 0 24px 60px -30px rgba(24,24,27,.25); }
  .hero-shot img { width: 100%; }
  @media (max-width: 640px) {
    .hero-trust { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 16px; }
    .hero-shot { margin-top: 40px; }
    .sec-intro { margin-bottom: 40px; }
  }

  /* ── Cards ── */
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 820px) { .grid-3 { grid-template-columns: 1fr; } .grid-2 { grid-template-columns: 1fr; } }
  .card { background: var(--bg); border: 1px solid var(--line); border-radius: 14px; padding: 28px; }
  .card .icon { width: 40px; height: 40px; border-radius: 10px; background: var(--accent-soft); border: 1px solid #FDE68A; display: flex; align-items: center; justify-content: center; margin-bottom: 18px; }
  .card .icon svg { width: 20px; height: 20px; stroke: var(--accent-ink); }

  /* ── Callout ── */
  .callout { background: var(--ink); color: #fff; border-radius: 16px; padding: 40px 44px; }
  .callout p { font-size: clamp(19px, 2.4vw, 24px); font-weight: 600; letter-spacing: -.015em; line-height: 1.4; }
  .callout span { color: var(--accent); }
  @media (max-width: 640px) { .callout { padding: 28px 24px; } }

  /* ── Is / Is not ── */
  .isnot .card ul { list-style: none; }
  .isnot .card li { display: flex; gap: 12px; align-items: flex-start; padding: 10px 0; font-size: 15px; line-height: 1.55; color: var(--body); border-top: 1px solid var(--line2); }
  .isnot .card li:first-of-type { border-top: none; }
  .isnot .card li svg { width: 18px; height: 18px; flex-shrink: 0; margin-top: 2px; }
  .li-yes svg { stroke: var(--green); }
  .li-no svg { stroke: var(--muted); }
  .isnot .label { font-size: 12px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; margin-bottom: 14px; display: block; }

  /* ── Build timeline ── */
  .build { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; counter-reset: step; }
  @media (max-width: 900px) { .build { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 620px) { .build { grid-template-columns: 1fr; } }
  .build-item { border: 1px solid var(--line); border-radius: 14px; padding: 22px; background: var(--bg); position: relative; }
  .build-num { font-size: 12px; font-weight: 600; color: var(--accent-ink); background: var(--accent-soft); border: 1px solid #FDE68A; border-radius: 999px; padding: 3px 10px; display: inline-block; margin-bottom: 14px; }
  .build-item .h3 { margin-bottom: 6px; }
  .build-item .small { color: var(--body); }

  /* ── Comparison table ── */
  .compare { border: 1px solid var(--line); border-radius: 16px; overflow: hidden; }
  .compare-head, .compare-row { display: grid; grid-template-columns: 1.1fr 1fr 1fr; }
  .compare-head { background: var(--bg2); border-bottom: 1px solid var(--line); }
  .compare-head div { padding: 16px 20px; font-size: 13px; font-weight: 600; letter-spacing: .02em; }
  .compare-head .col-own { color: var(--accent-ink); }
  .compare-row { border-top: 1px solid var(--line2); }
  .compare-row:first-of-type { border-top: none; }
  .compare-row div { padding: 16px 20px; font-size: 14px; line-height: 1.55; }
  .compare-row .rowlab { font-weight: 600; color: var(--ink); font-size: 13.5px; }
  .compare-row .blind { color: var(--muted); }
  .compare-row .own { color: var(--ink); background: #FFFDF6; }
  @media (max-width: 680px) {
    .compare-head { display: none; }
    .compare-row { grid-template-columns: 1fr; padding: 14px 0; }
    .compare-row div { padding: 4px 20px; }
    .compare-row .rowlab { padding-top: 8px; }
    .compare-row .blind::before { content: "Outsourcing blind — "; font-weight: 600; color: var(--muted); }
    .compare-row .own::before { content: "Owning it — "; font-weight: 600; color: var(--accent-ink); }
    .compare-row .own { background: transparent; }
  }

  /* ── After checklist ── */
  .after-list { list-style: none; max-width: 620px; }
  .after-list li { display: flex; gap: 14px; align-items: flex-start; padding: 14px 0; border-top: 1px solid var(--line2); font-size: 16px; line-height: 1.6; color: var(--body); }
  .after-list li:first-child { border-top: none; }
  .after-list svg { width: 20px; height: 20px; stroke: var(--green); flex-shrink: 0; margin-top: 3px; }

  /* ── FAQ ── */
  .faq { max-width: 720px; }
  .faq details { border-top: 1px solid var(--line); }
  .faq details:last-child { border-bottom: 1px solid var(--line); }
  .faq summary { cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 16px; padding: 22px 4px; font-size: 16.5px; font-weight: 600; letter-spacing: -.01em; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after { content: "+"; font-size: 20px; font-weight: 400; color: var(--muted); transition: transform .15s; }
  .faq details[open] summary::after { transform: rotate(45deg); }
  .faq .p { padding: 0 4px 24px; max-width: 640px; }

  /* ── Pricing ── */
  .price-card { border: 1px solid var(--line); border-radius: 20px; padding: 44px; background: var(--bg); box-shadow: 0 24px 60px -40px rgba(24,24,27,.3); max-width: 520px; }
  .price-row { display: flex; align-items: baseline; gap: 12px; margin: 8px 0 4px; }
  .price-big { font-size: 56px; font-weight: 700; letter-spacing: -.03em; }
  .price-was { font-size: 20px; color: var(--muted); text-decoration: line-through; }
  .price-inc { list-style: none; margin: 24px 0 28px; }
  .price-inc li { display: flex; gap: 10px; align-items: flex-start; padding: 7px 0; font-size: 14.5px; color: var(--body); }
  .price-inc svg { width: 17px; height: 17px; stroke: var(--green); flex-shrink: 0; margin-top: 3px; }
  @media (max-width: 640px) { .price-card { padding: 28px 22px; } }

  /* ── Footer ── */
  footer { border-top: 1px solid var(--line); padding: 40px 0 56px; }
  footer .tiny a { text-decoration: underline; text-underline-offset: 3px; }

  /* ── Free lessons modal ── */
  #fc-overlay { position: fixed; inset: 0; z-index: 10000; background: rgba(24,24,27,.5); backdrop-filter: blur(3px); display: none; align-items: flex-start; justify-content: center; overflow-y: auto; padding: 24px; }
  #fc-overlay.open { display: flex; }
  .fc-modal { background: var(--bg); border: 1px solid var(--line); border-radius: 18px; max-width: 640px; width: 100%; margin: auto; position: relative; padding: 36px 32px; }
  @media (max-width: 480px) { .fc-modal { padding: 26px 20px; } #fc-overlay { padding: 12px; } }
  .fc-close { position: absolute; top: 14px; right: 14px; background: none; border: none; font-size: 15px; color: var(--muted); cursor: pointer; padding: 6px; }
  .fc-close:hover { color: var(--ink); }
  .fc-kicker { font-size: 12px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--accent-ink); display: block; margin-bottom: 12px; }
  .fc-h { font-size: 26px; font-weight: 700; letter-spacing: -.025em; margin-bottom: 10px; }
  .fc-field { margin-bottom: 14px; }
  .fc-field label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; }
  .fc-field input { width: 100%; border: 1px solid var(--line); background: var(--bg2); padding: 13px 15px; font-size: 15px; font-family: inherit; color: var(--ink); border-radius: 10px; }
  .fc-field input:focus { outline: 2px solid var(--accent); outline-offset: -1px; }
  .fc-error { display: none; font-size: 13px; color: #B91C1C; margin-top: 10px; }
  .fc-video video { width: 100%; display: block; background: #000; aspect-ratio: 16 / 9; border: 1px solid var(--line); border-radius: 12px; }
  .fc-lessons { border: 1px solid var(--line); border-radius: 12px; overflow: hidden; margin-top: 20px; }
  .fc-lesson { display: flex; gap: 12px; align-items: center; padding: 11px 16px; border-top: 1px solid var(--line2); font-size: 13.5px; color: var(--body); }
  .fc-lesson:first-child { border-top: none; }
  .fc-lesson .num { font-size: 11.5px; font-weight: 600; color: var(--accent-ink); flex-shrink: 0; }
  .fc-lesson .fc-tag { margin-left: auto; font-size: 11.5px; flex-shrink: 0; }
  .fc-lesson.locked { color: var(--muted); background: var(--bg2); cursor: pointer; }
  .fc-lesson.locked:hover { background: var(--accent-soft); }
  .fc-lesson.fc-playable { cursor: pointer; transition: background .15s; }
  .fc-lesson.fc-playable:hover { background: var(--accent-soft); }
  .fc-lesson.fc-playable.active .fc-tag { color: var(--accent-ink); font-weight: 600; }
  .fc-lock-note { display: none; padding: 16px; background: var(--accent-soft); border-top: 1px solid var(--line2); }
  .fc-lock-note p { font-size: 13.5px; line-height: 1.55; color: var(--body); margin-bottom: 12px; }
  .fc-lock-note strong { color: var(--ink); }
  .fc-offer { background: var(--ink); color: #fff; border-radius: 14px; padding: 26px; margin-top: 20px; }
  .fc-offer .btn-light { display: block; width: 100%; background: #fff; color: var(--ink); padding: 15px; font-size: 14.5px; font-weight: 600; text-align: center; border: none; border-radius: 10px; cursor: pointer; }
  .fc-offer .btn-light:hover { background: var(--bg2); }
  .fc-attn { animation: fcPulse 1.2s ease-in-out 3; }
  @keyframes fcPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245,158,11,0); }
    50%      { box-shadow: 0 0 0 6px rgba(245,158,11,.45); }
  }
  #fc-next-cta { display: block; text-align: center; margin-top: 16px; width: 100%; }
</style>

