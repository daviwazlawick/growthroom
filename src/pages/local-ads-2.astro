<!-- WHO THIS IS FOR -->
<section class="sec-line who">
  <div class="container">
    <h2 class="h2" style="font-size:clamp(24px,3vw,32px); margin-bottom:12px;">Built for owners, not marketers.</h2>
    <div class="who-badges">
      <span class="who-badge">Dentists</span>
      <span class="who-badge">Doctors</span>
      <span class="who-badge">Clinics</span>
      <span class="who-badge">Physiotherapists</span>
      <span class="who-badge">Chiropractors</span>
      <span class="who-badge">Lawyers</span>
      <span class="who-badge">Restaurants</span>
      <span class="who-badge">Cafés</span>
      <span class="who-badge">Gyms</span>
      <span class="who-badge">Beauty salons</span>
      <span class="who-badge">Barbers</span>
