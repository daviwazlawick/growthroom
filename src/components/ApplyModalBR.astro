<style>
  #apply-modal-br {
    --m-bg:    #13131A;
    --m-bg1:   #1B1B22;
    --m-bg2:   #22222B;
    --m-line:  #2E2E38;
    --m-line2: #3A3A45;
    --m-fg:    #F7F7F2;
    --m-fg2:   #C8C8C2;
    --m-fg3:   #9A9A95;
    --m-fg4:   #6A6A66;
    --m-accent: #D8FF5C;
    --m-danger: #F55;
    --m-mono: "JetBrains Mono", ui-monospace, "SF Mono", monospace;
    --m-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  }

  #apply-modal-br {
    position: fixed;
    inset: 0;
    z-index: 2147483646;
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding: 24px 16px 40px;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    overflow-y: auto;
  }

  #apply-modal-br.open { display: flex; }

  #apply-modal-br .am-card {
    width: 100%;
    max-width: 680px;
    margin: auto;
    background: var(--m-bg);
    border: 1px solid var(--m-line);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(216,255,92,0.06);
    position: relative;
    flex-shrink: 0;
  }

  #apply-modal-br .am-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--m-line2);
    background: var(--m-bg1);
    color: var(--m-fg3);
    cursor: pointer;
    display: grid;
    place-items: center;
    font-size: 18px;
    line-height: 1;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    z-index: 10;
  }
  #apply-modal-br .am-close:hover {
    border-color: var(--m-fg3);
    color: var(--m-fg);
    background: var(--m-bg2);
  }

  #apply-modal-br .am-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    padding: 28px 32px;
    border-bottom: 1px solid var(--m-line);
    align-items: center;
    background: var(--m-bg1);
    padding-right: 64px;
  }

  #apply-modal-br .am-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--m-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--m-accent);
  }

  #apply-modal-br .am-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--m-accent);
    box-shadow: 0 0 10px rgba(216,255,92,0.6);
    flex-shrink: 0;
  }

  #apply-modal-br .am-title {
    margin-top: 8px;
    font-family: var(--m-sans);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--m-fg);
    line-height: 1.2;
  }

  #apply-modal-br .am-progress {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #apply-modal-br .am-pstep {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--m-mono);
    font-size: 10px;
    color: var(--m-fg4);
    letter-spacing: 0.08em;
  }

  #apply-modal-br .am-pdot {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1px solid var(--m-line2);
    display: grid;
    place-items: center;
    font-size: 10px;
    color: var(--m-fg3);
    transition: all 0.3s;
    flex-shrink: 0;
  }

  #apply-modal-br .am-pstep.done .am-pdot  { background: var(--m-accent); color: #0A0A0B; border-color: transparent; }
  #apply-modal-br .am-pstep.active .am-pdot { border-color: var(--m-accent); color: var(--m-accent); box-shadow: 0 0 0 4px rgba(216,255,92,0.12); }
  #apply-modal-br .am-pstep.done .am-plabel,
  #apply-modal-br .am-pstep.active .am-plabel { color: var(--m-fg); }

  #apply-modal-br .am-pbar {
    flex: 0 0 48px;
    height: 1px;
    background: var(--m-line);
    position: relative;
    overflow: hidden;
  }
  #apply-modal-br .am-pbar::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--m-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease;
  }
  #apply-modal-br .am-pstep.done + .am-pbar::after { transform: scaleX(1); }

  #apply-modal-br .am-body {
    padding: 36px 32px 28px;
    min-height: 280px;
    position: relative;
  }

  #apply-modal-br .am-pane { display: none; animation: amFadeInBR 0.4s ease both; }
  #apply-modal-br .am-pane.active { display: block; }
  @keyframes amFadeInBR { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }

  #apply-modal-br .am-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
  }

  #apply-modal-br .am-field label {
    font-family: var(--m-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--m-fg3);
  }

  #apply-modal-br .am-field input[type=text],
  #apply-modal-br .am-field input[type=email],
  #apply-modal-br .am-field input[type=tel] {
    background: var(--m-bg1);
    border: 1px solid var(--m-line);
    border-radius: 10px;
    padding: 14px 16px;
    color: var(--m-fg);
    font-size: 15px;
    font-family: var(--m-sans);
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    width: 100%;
    box-sizing: border-box;
  }
  #apply-modal-br .am-field input:focus { border-color: var(--m-accent); background: var(--m-bg2); }

  #apply-modal-br .am-field .am-err {
    font-family: var(--m-mono);
    font-size: 11px;
    color: var(--m-danger);
    letter-spacing: 0.04em;
    display: none;
  }
  #apply-modal-br .am-field.invalid input { border-color: var(--m-danger); }
  #apply-modal-br .am-field.invalid .am-err { display: block; }

  #apply-modal-br .am-row2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  #apply-modal-br .am-mcq {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  #apply-modal-br .am-mcq.three { grid-template-columns: repeat(3, 1fr); }

  #apply-modal-br .am-opt {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border: 1px solid var(--m-line2);
    border-radius: 10px;
    background: var(--m-bg1);
    cursor: pointer;
    transition: border-color 0.18s, background 0.18s;
    text-align: left;
  }
  #apply-modal-br .am-opt:hover { border-color: var(--m-fg4); background: var(--m-bg2); }
  #apply-modal-br .am-opt.on { background: var(--m-accent); border-color: transparent; }
  #apply-modal-br .am-opt.on .am-opt-text { color: #0A0A0B; }
  #apply-modal-br .am-opt.on .am-opt-meta { color: rgba(10,10,11,0.5); }

  #apply-modal-br .am-check-box {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1px solid var(--m-line2);
    background: var(--m-bg);
    display: grid;
    place-items: center;
    flex-shrink: 0;
    transition: background 0.15s, border-color 0.15s;
  }
  #apply-modal-br .am-opt.on .am-check-box { background: rgba(10,10,11,0.25); border-color: transparent; }
  #apply-modal-br .am-check-box svg { display: none; }
  #apply-modal-br .am-opt.on .am-check-box svg { display: block; }

  #apply-modal-br .am-opt-text {
    font-family: var(--m-sans);
    font-size: 13px;
    color: var(--m-fg2);
    flex: 1;
    line-height: 1.3;
  }
  #apply-modal-br .am-opt-meta {
    font-family: var(--m-mono);
    font-size: 10px;
    color: var(--m-fg4);
    letter-spacing: 0.08em;
    flex-shrink: 0;
  }

  #apply-modal-br .am-field.invalid .am-mcq { outline: 1px solid var(--m-danger); border-radius: 10px; }

  #apply-modal-br .am-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 32px;
    border-top: 1px solid var(--m-line);
    background: var(--m-bg1);
  }

  #apply-modal-br .am-step-label {
    font-family: var(--m-mono);
    font-size: 11px;
    color: var(--m-fg4);
    letter-spacing: 0.08em;
  }

  #apply-modal-br .am-actions { display: flex; gap: 10px; }

  #apply-modal-br .am-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 44px;
    padding: 0 22px;
    border-radius: 999px;
    font-family: var(--m-sans);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s, background 0.2s, border-color 0.2s, color 0.2s;
    border: none;
  }
  #apply-modal-br .am-btn:hover { transform: translateY(-1px); }

  #apply-modal-br .am-btn-primary {
    background: var(--m-accent);
    color: #13131A;
    box-shadow: 0 0 0 1px rgba(216,255,92,0.4), 0 8px 24px -6px rgba(216,255,92,0.35);
  }
  #apply-modal-br .am-btn-primary:hover { background: #e6ff7a; }
  #apply-modal-br .am-btn-primary:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

  #apply-modal-br .am-btn-ghost {
    background: var(--m-bg2);
    border: 1px solid var(--m-line2);
    color: var(--m-fg2);
  }
  #apply-modal-br .am-btn-ghost:hover { border-color: var(--m-fg3); color: var(--m-fg); }

  #apply-modal-br .am-form-hint {
    font-family: var(--m-mono);
    font-size: 11px;
    color: var(--m-fg4);
    letter-spacing: 0.04em;
    margin-top: 10px;
  }

  #apply-modal-br .am-error-msg {
    margin-top: 12px;
    padding: 12px 16px;
    border-radius: 8px;
    border: 1px solid rgba(255, 85, 85, 0.3);
    background: rgba(255, 85, 85, 0.08);
    font-family: var(--m-mono);
    font-size: 12px;
    color: var(--m-danger);
    display: none;
  }

  #apply-modal-br .am-success {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    padding: 48px 32px;
  }
  #apply-modal-br .am-success.show { display: flex; }

  #apply-modal-br .am-success-check {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--m-accent);
    display: grid;
    place-items: center;
    color: #13131A;
    font-family: var(--m-mono);
    font-weight: 700;
    font-size: 22px;
    animation: amPopBR 0.5s ease both;
  }
  @keyframes amPopBR { 0% { transform: scale(0.6); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }

  #apply-modal-br .am-success-meta {
    font-family: var(--m-mono);
    font-size: 11px;
    color: var(--m-fg3);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  #apply-modal-br .am-success h3 {
    font-family: var(--m-sans);
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--m-fg);
    margin: 0;
  }

  #apply-modal-br .am-success p {
    font-family: var(--m-sans);
    font-size: 15px;
    color: var(--m-fg2);
    line-height: 1.6;
    max-width: 46ch;
    margin: 0;
  }

  #apply-modal-br .am-success-email {
    font-family: var(--m-mono);
    font-size: 12px;
    color: var(--m-fg3);
    letter-spacing: 0.04em;
  }
  #apply-modal-br .am-success-email span { color: var(--m-fg); }

  @media (max-width: 600px) {
    #apply-modal-br .am-head { padding: 22px 20px; padding-right: 56px; gap: 12px; }
    #apply-modal-br .am-body { padding: 24px 20px 20px; }
    #apply-modal-br .am-foot { padding: 16px 20px; }
    #apply-modal-br .am-progress { display: none; }
    #apply-modal-br .am-mcq, #apply-modal-br .am-mcq.three { grid-template-columns: 1fr; }
    #apply-modal-br .am-row2 { grid-template-columns: 1fr; }
    #apply-modal-br .am-success { padding: 32px 20px; }
  }
</style>

<div id="apply-modal-br" role="dialog" aria-modal="true" aria-label="Candidatura Growth Room">
  <div class="am-card">

    <button class="am-close" id="ambr-close-btn" aria-label="Fechar">&times;</button>

    <div class="am-head">
      <div>
        <div class="am-eyebrow">
          <span class="am-eyebrow-dot"></span>
          <span id="ambr-eyebrow-text">Candidatura</span>
        </div>
        <h3 class="am-title" id="ambr-title">Qual é o seu estágio atual?</h3>
      </div>
      <div class="am-progress" aria-label="Progresso do formulário">
        <div class="am-pstep active" data-step="1">
          <span class="am-pdot">1</span>
          <span class="am-plabel">Estágio</span>
        </div>
        <div class="am-pbar"></div>
        <div class="am-pstep" data-step="2">
          <span class="am-pdot">2</span>
          <span class="am-plabel">Canais</span>
        </div>
        <div class="am-pbar"></div>
        <div class="am-pstep" data-step="3">
          <span class="am-pdot">3</span>
          <span class="am-plabel">Bloqueio</span>
        </div>
        <div class="am-pbar"></div>
        <div class="am-pstep" data-step="4">
          <span class="am-pdot">4</span>
          <span class="am-plabel">Contato</span>
        </div>
      </div>
    </div>

    <form id="ambr-form" class="am-body" novalidate>

      <!-- Passo 1: Verba -->
      <div class="am-pane active" data-pane="1">
        <div class="am-field" data-field="spend">
          <label>Qual é o seu investimento mensal em anúncios?</label>
          <div class="am-mcq" id="ambr-mcq-spend">
            <button type="button" class="am-opt" data-val="&lt;1K">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">Menos de R$1K / mês</span>
              <span class="am-opt-meta">01</span>
            </button>
            <button type="button" class="am-opt" data-val="1-5K">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">R$1K – R$5K / mês</span>
              <span class="am-opt-meta">02</span>
            </button>
            <button type="button" class="am-opt" data-val="5-20K">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">R$5K – R$20K / mês</span>
              <span class="am-opt-meta">03</span>
            </button>
            <button type="button" class="am-opt" data-val="20-80K">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">R$20K – R$80K / mês</span>
              <span class="am-opt-meta">04</span>
            </button>
            <button type="button" class="am-opt" data-val="80-300K">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">R$80K – R$300K / mês</span>
              <span class="am-opt-meta">05</span>
            </button>
            <button type="button" class="am-opt" data-val="300K+">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">R$300K+ / mês</span>
              <span class="am-opt-meta">06</span>
            </button>
          </div>
          <span class="am-err">Selecione a faixa mais próxima do seu investimento atual.</span>
        </div>
      </div>

      <!-- Passo 2: Canais -->
      <div class="am-pane" data-pane="2">
        <div class="am-field" data-field="channels">
          <label>Quais canais você está usando? (selecione todos que se aplicam)</label>
          <div class="am-mcq three" id="ambr-mcq-channels">
            <button type="button" class="am-opt" data-val="Meta">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">Meta</span>
            </button>
            <button type="button" class="am-opt" data-val="Google">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">Google</span>
            </button>
            <button type="button" class="am-opt" data-val="TikTok">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">TikTok</span>
            </button>
            <button type="button" class="am-opt" data-val="LinkedIn">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">LinkedIn</span>
            </button>
            <button type="button" class="am-opt" data-val="YouTube">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">YouTube</span>
            </button>
            <button type="button" class="am-opt" data-val="Outro">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">Outro</span>
            </button>
          </div>
          <span class="am-err">Selecione pelo menos um canal.</span>
        </div>
      </div>

      <!-- Passo 3: Bloqueio -->
      <div class="am-pane" data-pane="3">
        <div class="am-field" data-field="blocker">
          <label>Qual é o maior obstáculo que você enfrenta agora?</label>
          <div class="am-mcq" id="ambr-mcq-blocker">
            <button type="button" class="am-opt" data-val="tracking">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">Rastreamento e atribuição não batem</span>
            </button>
            <button type="button" class="am-opt" data-val="roas">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">ROAS volátil / não é lucrativo</span>
            </button>
            <button type="button" class="am-opt" data-val="creative">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">Criativo travado / não converte</span>
            </button>
            <button type="button" class="am-opt" data-val="scale">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">Não consigo escalar além do teto atual</span>
            </button>
            <button type="button" class="am-opt" data-val="priority">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">Sem prioridade clara — dashboards demais</span>
            </button>
            <button type="button" class="am-opt" data-val="other">
              <span class="am-check-box"><svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 6 L5 9 L10 3" stroke="#0A0A0B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="am-opt-text">Outro</span>
            </button>
          </div>
          <span class="am-err">Selecione a opção mais próxima — vamos aprofundar na reunião.</span>
        </div>
      </div>

      <!-- Passo 4: Contato -->
      <div class="am-pane" data-pane="4">
        <div class="am-row2">
          <div class="am-field" data-field="name">
            <label for="ambr-name">Nome completo</label>
            <input id="ambr-name" type="text" autocomplete="name" placeholder="João Silva" required />
            <span class="am-err">Por favor, insira seu nome completo.</span>
          </div>
          <div class="am-field" data-field="email">
            <label for="ambr-email">E-mail</label>
            <input id="ambr-email" type="email" autocomplete="email" placeholder="joao@suaempresa.com" required />
            <span class="am-err">Por favor, insira um e-mail válido.</span>
          </div>
        </div>
        <div class="am-field" data-field="phone">
          <label for="ambr-phone">WhatsApp / Telefone</label>
          <input id="ambr-phone" type="tel" autocomplete="tel" placeholder="+55 11 99999-9999" required />
          <span class="am-err">Por favor, insira um número de telefone válido.</span>
        </div>
        <p class="am-form-hint">Ao enviar você concorda com uma reunião de intro de 15 minutos. Nunca vendemos seus dados.</p>
        <div class="am-error-msg" id="ambr-error-msg">Algo deu errado — tente novamente.</div>
      </div>

      <!-- Sucesso -->
      <div class="am-success" id="ambr-success">
        <div class="am-success-check">✓</div>
        <p class="am-success-meta" id="ambr-success-meta">Candidatura recebida</p>
        <h3 id="ambr-success-name">Você está na fila.</h3>
        <p>Um especialista vai revisar seu briefing e responder em até 48 horas — com um match de grupo ou um "ainda não, e aqui está o porquê."</p>
        <p class="am-success-email">Confirmação enviada para <span id="ambr-success-email">—</span></p>
      </div>

    </form>

    <div class="am-foot" id="ambr-foot">
      <span class="am-step-label" id="ambr-step-label">Passo 01 de 04</span>
      <div class="am-actions">
        <button type="button" class="am-btn am-btn-ghost" id="ambr-back-btn" style="display:none">← Voltar</button>
        <button type="button" class="am-btn am-btn-primary" id="ambr-next-btn">
          Continuar <span style="transition:transform .2s;display:inline-block">→</span>
        </button>
      </div>
    </div>

  </div>
</div>

<script is:inline>
(function () {
  var modal     = document.getElementById('apply-modal-br');
  var closeBtn  = document.getElementById('ambr-close-btn');
  var form      = document.getElementById('ambr-form');
  var foot      = document.getElementById('ambr-foot');
  var title     = document.getElementById('ambr-title');
  var stepLabel = document.getElementById('ambr-step-label');
  var backBtn   = document.getElementById('ambr-back-btn');
  var nextBtn   = document.getElementById('ambr-next-btn');
  var errorMsg  = document.getElementById('ambr-error-msg');
  var success   = document.getElementById('ambr-success');
  if (!modal) return;

  var curStep = 1;
  var totalSteps = 4;
  var selectedProduct = '';

  var titles = {
    1: 'Qual é o seu estágio atual?',
    2: 'Onde você está rodando anúncios?',
    3: 'O que está te bloqueando mais?',
    4: 'Como podemos te contatar?'
  };

  window.openApplyModal = function (product) {
    selectedProduct = product || '';
    var eyebrow = document.getElementById('ambr-eyebrow-text');
    if (eyebrow) eyebrow.textContent = selectedProduct ? 'Candidatura · ' + selectedProduct : 'Candidatura';
    resetForm();
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
    document.documentElement.style.overflow = 'hidden';
  };

  function closeModal() {
    modal.classList.remove('open');
    document.body.style.overflow = '';
    document.documentElement.style.overflow = '';
  }

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
  });

  document.addEventListener('click', function (e) {
    var link = e.target.closest('a[href="#apply"], a[href$="#apply"]');
    if (!link) return;
    e.preventDefault();
    window.openApplyModal(link.dataset.product || '');
  });

  function setupMCQ(rootId, multi) {
    var root = document.getElementById(rootId);
    if (!root) return;
    root.querySelectorAll('.am-opt').forEach(function (b) {
      b.addEventListener('click', function () {
        if (multi) {
          b.classList.toggle('on');
        } else {
          root.querySelectorAll('.am-opt').forEach(function (x) { x.classList.remove('on'); });
          b.classList.add('on');
        }
        var field = b.closest('.am-field');
        if (field && field.classList.contains('invalid')) validateStep(curStep);
      });
    });
  }
  setupMCQ('ambr-mcq-spend', false);
  setupMCQ('ambr-mcq-channels', true);
  setupMCQ('ambr-mcq-blocker', false);

  function setStep(n) {
    curStep = n;
    form.querySelectorAll('.am-pane').forEach(function (p) {
      p.classList.toggle('active', parseInt(p.dataset.pane, 10) === n);
    });
    modal.querySelectorAll('.am-pstep').forEach(function (p) {
      var s = parseInt(p.dataset.step, 10);
      p.classList.toggle('done', s < n);
      p.classList.toggle('active', s === n);
    });
    title.textContent = titles[n];
    stepLabel.textContent = 'Passo ' + String(n).padStart(2, '0') + ' de ' + String(totalSteps).padStart(2, '0');
    backBtn.style.display = n > 1 ? 'inline-flex' : 'none';
    nextBtn.innerHTML = n === totalSteps
      ? 'Enviar candidatura <span style="transition:transform .2s;display:inline-block">→</span>'
      : 'Continuar <span style="transition:transform .2s;display:inline-block">→</span>';
    var card = modal.querySelector('.am-card');
    if (card) card.scrollIntoView({ block: 'nearest' });
  }

  function resetForm() {
    modal.querySelectorAll('.am-opt').forEach(function (b) { b.classList.remove('on'); });
    modal.querySelectorAll('.am-field').forEach(function (f) { f.classList.remove('invalid'); });
    modal.querySelectorAll('input').forEach(function (i) { i.value = ''; });
    if (errorMsg) errorMsg.style.display = 'none';
    success.classList.remove('show');
    foot.style.display = '';
    setStep(1);
  }

  function setInvalid(el, bad) {
    var field = el && el.classList && el.classList.contains('am-field')
      ? el : el && el.closest ? el.closest('.am-field') : null;
    if (field) field.classList.toggle('invalid', bad);
  }

  function validateStep(n) {
    var ok = true;
    if (n === 1) {
      var sel = modal.querySelectorAll('#ambr-mcq-spend .am-opt.on');
      setInvalid(modal.querySelector('[data-field=spend]'), sel.length === 0);
      ok = sel.length > 0;
    }
    if (n === 2) {
      var sel = modal.querySelectorAll('#ambr-mcq-channels .am-opt.on');
      setInvalid(modal.querySelector('[data-field=channels]'), sel.length === 0);
      ok = sel.length > 0;
    }
    if (n === 3) {
      var sel = modal.querySelectorAll('#ambr-mcq-blocker .am-opt.on');
      setInvalid(modal.querySelector('[data-field=blocker]'), sel.length === 0);
      ok = sel.length > 0;
    }
    if (n === 4) {
      var name  = document.getElementById('ambr-name');
      var email = document.getElementById('ambr-email');
      var phone = document.getElementById('ambr-phone');
      var nOk = name.value.trim().length >= 2;
      var eOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value);
      var pOk = phone.value.trim().length >= 5;
      setInvalid(name, !nOk);
      setInvalid(email, !eOk);
      setInvalid(phone, !pOk);
      ok = nOk && eOk && pOk;
    }
    return ok;
  }

  backBtn.addEventListener('click', function () { if (curStep > 1) setStep(curStep - 1); });

  nextBtn.addEventListener('click', function () {
    if (!validateStep(curStep)) return;
    if (curStep < totalSteps) {
      setStep(curStep + 1);
    } else {
      submitForm();
    }
  });

  ['ambr-name', 'ambr-email', 'ambr-phone'].forEach(function (id) {
    var el = document.getElementById(id);
    if (!el) return;
    el.addEventListener('input', function () {
      if (el.closest('.am-field').classList.contains('invalid')) validateStep(curStep);
    });
  });

  async function submitForm() {
    if (errorMsg) errorMsg.style.display = 'none';
    nextBtn.disabled = true;
    nextBtn.innerHTML = 'Enviando…';

    var spend    = (modal.querySelector('#ambr-mcq-spend .am-opt.on') || {}).dataset?.val || '';
    var channels = Array.from(modal.querySelectorAll('#ambr-mcq-channels .am-opt.on'))
                        .map(function (b) { return b.dataset.val; }).join(', ');
    var blocker  = (modal.querySelector('#ambr-mcq-blocker .am-opt.on') || {}).dataset?.val || '';
    var fullName = document.getElementById('ambr-name').value.trim();
    var email    = document.getElementById('ambr-email').value.trim();
    var phone    = document.getElementById('ambr-phone').value.trim();

    var nameParts = fullName.split(/\s+/);
    var firstName = nameParts[0] || '';
    var lastName  = nameParts.slice(1).join(' ') || '';

    var trackingPayload = {};
    try {
      if (typeof window.submitMetaForm === 'function') {
        trackingPayload = await window.submitMetaForm({
          firstName: firstName, lastName: lastName,
          email: email, phone: phone,
          channels: channels, monthlySpend: spend, biggestBlocker: blocker
        });
      }
    } catch (e) {}

    try {
      var res = await fetch('/api/leads', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(Object.assign({}, {
          fullName: fullName, email: email, phone: phone,
          channels: channels, monthlySpend: spend, biggestBlocker: blocker,
          product: selectedProduct, locale: 'pt-BR'
        }, trackingPayload))
      });
      if (!res.ok) throw new Error('api_error');

      form.querySelectorAll('.am-pane').forEach(function (p) { p.classList.remove('active'); });
      success.classList.add('show');
      foot.style.display = 'none';
      title.textContent = selectedProduct ? 'Você está dentro — ' + selectedProduct : 'Você está dentro!';
      var successMeta = document.getElementById('ambr-success-meta');
      if (successMeta) successMeta.textContent = selectedProduct ? 'Candidatura recebida · ' + selectedProduct : 'Candidatura recebida';
      document.getElementById('ambr-success-email').textContent = email || '—';
      document.getElementById('ambr-success-name').textContent = 'Você está na fila, ' + firstName + '.';
      modal.querySelectorAll('.am-pstep').forEach(function (p) { p.classList.add('done'); p.classList.remove('active'); });
    } catch (e) {
      nextBtn.disabled = false;
      nextBtn.innerHTML = 'Enviar candidatura <span style="transition:transform .2s;display:inline-block">→</span>';
      if (errorMsg) errorMsg.style.display = 'block';
    }
  }

  setStep(1);
})();
</script>
