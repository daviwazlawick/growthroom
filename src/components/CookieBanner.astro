<section id="cookie-banner" class="fixed inset-0 z-[2147483647] flex items-center justify-center bg-black/75 px-4 backdrop-blur-sm">
  <div class="w-full max-w-xl rounded-2xl border border-[#C9A44A]/30 bg-black/90 p-6 shadow-[0_24px_64px_rgba(0,0,0,0.55)] sm:p-7">
    <p class="section-label">Privacy & Cookies</p>
    <h3 class="mt-2 text-xl font-bold text-white">
      Your data, your choice.
    </h3>
    <p class="mt-2 text-sm leading-relaxed text-zinc-300">
      We use necessary cookies to run the site and optional analytics/marketing cookies only with your consent.
      You can accept, reject, or customize your preferences at any time.
    </p>

    <div class="mt-5 flex flex-wrap gap-2">
      <button
        id="cookie-reject"
        type="button"
        onclick="window.growthroomCookieReject && window.growthroomCookieReject()"
        class="rounded-lg border border-white/15 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:bg-white/5"
      >
        Reject optional
      </button>
      <button
        id="cookie-customize"
        type="button"
        onclick="window.growthroomCookieCustomize && window.growthroomCookieCustomize()"
        class="rounded-lg border border-[#C9A44A]/35 px-4 py-2 text-sm font-semibold text-[#C9A44A] transition hover:bg-[#C9A44A]/10"
      >
        Customize
      </button>
      <button
        id="cookie-accept"
        type="button"
        onclick="window.growthroomCookieAccept && window.growthroomCookieAccept()"
        class="btn-gold !px-5 !py-2 !text-sm"
      >
        Accept all
      </button>
    </div>

    <div id="cookie-fallback-panel" class="mt-4 hidden rounded-xl border border-white/10 bg-white/5 p-4">
      <p class="text-sm font-semibold text-white">Customize cookie categories</p>
      <p class="mt-1 text-xs text-zinc-400">Necessary cookies are always active.</p>
      <label class="mt-3 flex items-center gap-2 text-sm text-zinc-200">
        <input id="cookie-opt-analytics" type="checkbox" class="accent-[#C9A44A]" />
        Analytics
      </label>
      <label class="mt-2 flex items-center gap-2 text-sm text-zinc-200">
        <input id="cookie-opt-marketing" type="checkbox" class="accent-[#C9A44A]" />
        Marketing
      </label>
      <button
        id="cookie-save-preferences"
        type="button"
        onclick="window.growthroomCookieSavePreferences && window.growthroomCookieSavePreferences()"
        class="mt-4 rounded-lg border border-[#C9A44A]/35 px-4 py-2 text-sm font-semibold text-[#C9A44A] transition hover:bg-[#C9A44A]/10"
      >
        Save preferences
      </button>
    </div>
  </div>
</section>

<script>
  (function () {
    try {
      const banner = document.getElementById("cookie-banner");
      if (!banner) return;

      const CONSENT_COOKIE = "growthroom_cookie_choice_v1";
      const CONSENT_MAX_AGE_DAYS = 180;
      const fallbackPanel = document.getElementById("cookie-fallback-panel");
      const analyticsOpt = document.getElementById("cookie-opt-analytics");
      const marketingOpt = document.getElementById("cookie-opt-marketing");

      let _bannerVisible = false;

      const show = () => {
        _bannerVisible = true;
        banner.style.position = "fixed";
        banner.style.inset = "0";
        banner.style.display = "flex";
        banner.style.alignItems = "center";
        banner.style.justifyContent = "center";
        banner.style.zIndex = "2147483647";
        banner.classList.remove("hidden");
        fallbackPanel?.classList.add("hidden");
        document.documentElement.classList.add("cookie-modal-open");
        document.body.classList.add("cookie-modal-open");
      };

      const hide = () => {
        _bannerVisible = false;
        banner.style.display = "none";
        banner.classList.add("hidden");
        document.documentElement.classList.remove("cookie-modal-open");
        document.body.classList.remove("cookie-modal-open");
      };

      const setChoiceCookie = (choice) => {
        const maxAge = CONSENT_MAX_AGE_DAYS * 24 * 60 * 60;
        const secure = window.location.protocol === "https:" ? "; Secure" : "";
        document.cookie =
          `${CONSENT_COOKIE}=${encodeURIComponent(choice)}; Path=/; Max-Age=${maxAge}; SameSite=Lax${secure}`;
      };

      const readChoiceCookie = () => {
        const prefix = `${CONSENT_COOKIE}=`;
        const parts = document.cookie.split(";").map((part) => part.trim());
        for (const part of parts) {
          if (part.startsWith(prefix)) {
            return decodeURIComponent(part.slice(prefix.length));
          }
        }
        return "";
      };

      const updateConsentMode = (analytics, marketing) => {
        if (typeof window.gtag !== "function") return;
        window.gtag("consent", "update", {
          analytics_storage: analytics ? "granted" : "denied",
          ad_storage: marketing ? "granted" : "denied",
          ad_user_data: marketing ? "granted" : "denied",
          ad_personalization: marketing ? "granted" : "denied",
        });
        window.dispatchEvent(new CustomEvent('growthroom:consent-updated', {
          detail: { analytics: !!analytics, marketing: !!marketing }
        }));
      };

      const applyStateFromHelper = () => {
        if (typeof window.getGrowthroomConsentState !== "function") return false;
        const state = window.getGrowthroomConsentState();
        updateConsentMode(!!state.analytics, !!state.marketing);
        return true;
      };

      const tryUcAcceptAll = () => {
        try {
          const uc = window.UC_UI;
          if (!uc) return false;
          if (typeof uc.acceptAllServices === "function") { uc.acceptAllServices(); return true; }
          if (typeof uc.acceptAllConsents === "function") { uc.acceptAllConsents(); return true; }
          return false;
        } catch (_) {
          return false;
        }
      };

      const tryUcRejectOptional = () => {
        try {
          const uc = window.UC_UI;
          if (!uc) return false;
          if (typeof uc.denyAllServices === "function") { uc.denyAllServices(); return true; }
          if (typeof uc.rejectAllConsents === "function") { uc.rejectAllConsents(); return true; }
          if (typeof uc.denyAllConsents === "function") { uc.denyAllConsents(); return true; }
          return false;
        } catch (_) {
          return false;
        }
      };

      let awaitingCustomizeChoice = false;

      const openCustomize = () => {
        awaitingCustomizeChoice = true;
        if (typeof window.openPrivacySettings === "function") {
          hide();
          window.openPrivacySettings();
          return;
        }
        awaitingCustomizeChoice = false;
        fallbackPanel?.classList.remove("hidden");
      };

      const onAccept = () => {
        const handledByUc = tryUcAcceptAll();
        if (!handledByUc) {
          updateConsentMode(true, true);
        } else {
          applyStateFromHelper();
        }
        setChoiceCookie("accepted");
        hide();
      };

      const onReject = () => {
        const handledByUc = tryUcRejectOptional();
        if (!handledByUc) {
          updateConsentMode(false, false);
        } else {
          applyStateFromHelper();
        }
        setChoiceCookie("rejected");
        hide();
      };

      const onCustomize = () => openCustomize();
      const onSavePreferences = () => {
        const analytics = !!analyticsOpt?.checked;
        const marketing = !!marketingOpt?.checked;
        updateConsentMode(analytics, marketing);
        setChoiceCookie("customized");
        hide();
      };

      window.growthroomCookieAccept = onAccept;
      window.growthroomCookieReject = onReject;
      window.growthroomCookieCustomize = onCustomize;
      window.growthroomCookieSavePreferences = onSavePreferences;

      window.addEventListener("UC_CONSENT", () => {
        if (!awaitingCustomizeChoice) return;
        awaitingCustomizeChoice = false;
        applyStateFromHelper();
        setChoiceCookie("customized");
        hide();
      });

      window.addEventListener("growthroom:consent-updated", () => {
        if (readChoiceCookie()) {
          hide();
        }
      });

      document.documentElement.style.overflow = "";
      document.body.style.overflow = "";
      banner.classList.add("hidden");

      if (readChoiceCookie()) {
        hide();
      } else {
        show();
      }

      const guard = () => {
        if (!_bannerVisible) {
          document.documentElement.style.overflow = "";
          document.body.style.overflow = "";
        }
      };
      requestAnimationFrame(guard);
      setTimeout(guard, 200);
      setTimeout(guard, 800);
      window.addEventListener("resize", guard);
      document.addEventListener("visibilitychange", guard);
    } catch (_) {
      document.documentElement.style.overflow = "";
      document.body.style.overflow = "";
    }
  })();
</script>
