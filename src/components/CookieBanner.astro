<section id="cookie-banner" class="fixed inset-0 z-[2147483647] flex items-center justify-center bg-black/75 px-4 backdrop-blur-sm">
  <div class="w-full max-w-xl rounded-2xl border border-[#C9A44A]/30 bg-black/90 p-6 shadow-[0_24px_64px_rgba(0,0,0,0.55)] sm:p-7">
    <p class="section-label">Privacy & Cookies</p>
    <h3 class="mt-2 text-xl font-bold text-white">
      Your data, your choice.
    </h3>
    <p class="mt-2 text-sm leading-relaxed text-zinc-300">
      We use necessary cookies to run the site and optional analytics/marketing cookies only with your consent.
      You can accept, reject, or customize your preferences at any time.
    </p>

    <div class="mt-5 flex flex-wrap gap-2">
      <button
        id="cookie-reject"
        type="button"
        onclick="window.growthroomCookieReject && window.growthroomCookieReject()"
        class="rounded-lg border border-white/15 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:bg-white/5"
      >
        Reject optional
      </button>
      <button
        id="cookie-customize"
        type="button"
        onclick="window.growthroomCookieCustomize && window.growthroomCookieCustomize()"
        class="rounded-lg border border-[#C9A44A]/35 px-4 py-2 text-sm font-semibold text-[#C9A44A] transition hover:bg-[#C9A44A]/10"
      >
        Customize
      </button>
      <button
        id="cookie-accept"
        type="button"
        onclick="window.growthroomCookieAccept && window.growthroomCookieAccept()"
        class="btn-gold !px-5 !py-2 !text-sm"
      >
        Accept all
      </button>
    </div>

    <div id="cookie-fallback-panel" class="mt-4 hidden rounded-xl border border-white/10 bg-white/5 p-4">
      <p class="text-sm font-semibold text-white">Customize cookie categories</p>
      <p class="mt-1 text-xs text-zinc-400">Necessary cookies are always active.</p>
      <label class="mt-3 flex items-center gap-2 text-sm text-zinc-200">
        <input id="cookie-opt-analytics" type="checkbox" class="accent-[#C9A44A]" />
        Analytics
      </label>
      <label class="mt-2 flex items-center gap-2 text-sm text-zinc-200">
        <input id="cookie-opt-marketing" type="checkbox" class="accent-[#C9A44A]" />
        Marketing
      </label>
      <button
        id="cookie-save-preferences"
        type="button"
        onclick="window.growthroomCookieSavePreferences && window.growthroomCookieSavePreferences()"
        class="mt-4 rounded-lg border border-[#C9A44A]/35 px-4 py-2 text-sm font-semibold text-[#C9A44A] transition hover:bg-[#C9A44A]/10"
      >
        Save preferences
      </button>
    </div>
  </div>
</section>

<script>
  (function () {
    try {
      const banner = document.getElementById("cookie-banner");
      if (!banner) return;

      const CONSENT_COOKIE = "growthroom_cookie_choice_v1";
      const CONSENT_MAX_AGE_DAYS = 180;
      const fallbackPanel = document.getElementById("cookie-fallback-panel");
      const analyticsOpt = document.getElementById("cookie-opt-analytics");
      const marketingOpt = document.getElementById("cookie-opt-marketing");

      const isBannerVisible = () =>
        !banner.classList.contains("hidden") &&
        !!(banner.offsetParent || banner.getClientRects().length);

      const show = () => {
        // #region agent log
        fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',runId:'pre-fix',hypothesisId:'H1',location:'CookieBanner.astro:show',message:'show() called',data:{cookie:readChoiceCookie()},timestamp:Date.now()})}).catch(()=>{});
        // #endregion
        banner.style.position = "fixed";
        banner.style.inset = "0";
        banner.style.display = "flex";
        banner.style.alignItems = "center";
        banner.style.justifyContent = "center";
        banner.style.zIndex = "2147483647";
        banner.classList.remove("hidden");
        fallbackPanel?.classList.add("hidden");
        document.documentElement.classList.add("cookie-modal-open");
        document.body.classList.add("cookie-modal-open");
      };

      const hide = () => {
        // #region agent log
        fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',runId:'pre-fix',hypothesisId:'H1',location:'CookieBanner.astro:hide',message:'hide() called',data:{cookie:readChoiceCookie()},timestamp:Date.now()})}).catch(()=>{});
        // #endregion
        banner.style.display = "none";
        banner.classList.add("hidden");
        document.documentElement.classList.remove("cookie-modal-open");
        document.body.classList.remove("cookie-modal-open");
      };

      const setChoiceCookie = (choice) => {
        const maxAge = CONSENT_MAX_AGE_DAYS * 24 * 60 * 60;
        const secure = window.location.protocol === "https:" ? "; Secure" : "";
        document.cookie =
          `${CONSENT_COOKIE}=${encodeURIComponent(choice)}; Path=/; Max-Age=${maxAge}; SameSite=Lax${secure}`;
        // #region agent log
        fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',runId:'pre-fix',hypothesisId:'H6',location:'CookieBanner.astro:setChoiceCookie',message:'consent cookie written',data:{choice:choice,cookieAfter:document.cookie.indexOf(CONSENT_COOKIE+'=')!==-1},timestamp:Date.now()})}).catch(()=>{});
        // #endregion
      };

      const readChoiceCookie = () => {
        const prefix = `${CONSENT_COOKIE}=`;
        const parts = document.cookie.split(";").map((part) => part.trim());
        for (const part of parts) {
          if (part.startsWith(prefix)) {
            return decodeURIComponent(part.slice(prefix.length));
          }
        }
        return "";
      };

      const updateConsentMode = (analytics, marketing) => {
        if (typeof window.gtag !== "function") return;
        window.gtag("consent", "update", {
          analytics_storage: analytics ? "granted" : "denied",
          ad_storage: marketing ? "granted" : "denied",
          ad_user_data: marketing ? "granted" : "denied",
          ad_personalization: marketing ? "granted" : "denied",
        });
        // #region agent log
        fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',runId:'post-fix',hypothesisId:'H8',location:'CookieBanner.astro:updateConsentMode',message:'dispatching growthroom consent update',data:{analytics:analytics,marketing:marketing},timestamp:Date.now()})}).catch(()=>{});
        // #endregion
        window.dispatchEvent(new CustomEvent('growthroom:consent-updated', {
          detail: { analytics: !!analytics, marketing: !!marketing }
        }));
      };

      const applyStateFromHelper = () => {
        if (typeof window.getGrowthroomConsentState !== "function") return false;
        const state = window.getGrowthroomConsentState();
        updateConsentMode(!!state.analytics, !!state.marketing);
        return true;
      };

      const tryUcAcceptAll = () => {
        try {
          const uc = window.UC_UI;
          if (!uc) return false;
          if (typeof uc.acceptAllServices === "function") { uc.acceptAllServices(); return true; }
          if (typeof uc.acceptAllConsents === "function") { uc.acceptAllConsents(); return true; }
          return false;
        } catch (_) {
          return false;
        }
      };

      const tryUcRejectOptional = () => {
        try {
          const uc = window.UC_UI;
          if (!uc) return false;
          if (typeof uc.denyAllServices === "function") { uc.denyAllServices(); return true; }
          if (typeof uc.rejectAllConsents === "function") { uc.rejectAllConsents(); return true; }
          if (typeof uc.denyAllConsents === "function") { uc.denyAllConsents(); return true; }
          return false;
        } catch (_) {
          return false;
        }
      };

      let awaitingCustomizeChoice = false;

      const openCustomize = () => {
        // #region agent log
        fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',runId:'pre-fix',hypothesisId:'H6',location:'CookieBanner.astro:openCustomize',message:'customize handler entered',data:{hasOpenPrivacy:typeof window.openPrivacySettings==='function',hasUC:!!window.UC_UI},timestamp:Date.now()})}).catch(()=>{});
        // #endregion
        awaitingCustomizeChoice = true;
        if (typeof window.openPrivacySettings === "function") {
          // Hide custom layer first so Usercentrics layer can receive clicks.
          hide();
          window.openPrivacySettings();
          return;
        }
        // Fallback: show in-banner category controls.
        awaitingCustomizeChoice = false;
        fallbackPanel?.classList.remove("hidden");
        // #region agent log
        fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',runId:'post-fix',hypothesisId:'H7',location:'CookieBanner.astro:openCustomize',message:'fallback preference panel shown',data:{reason:'openPrivacySettings missing'},timestamp:Date.now()})}).catch(()=>{});
        // #endregion
      };

      const onAccept = () => {
        // #region agent log
        fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',runId:'pre-fix',hypothesisId:'H2',location:'CookieBanner.astro:onAccept',message:'accept handler triggered',data:{hasUC:!!window.UC_UI,hasGtag:typeof window.gtag==='function'},timestamp:Date.now()})}).catch(()=>{});
        // #endregion
        // Close first for immediate UX feedback.
        const handledByUc = tryUcAcceptAll();
        if (!handledByUc) {
          updateConsentMode(true, true);
        } else {
          applyStateFromHelper();
        }
        setChoiceCookie("accepted");
        hide();
      };

      const onReject = () => {
        // #region agent log
        fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',runId:'pre-fix',hypothesisId:'H2',location:'CookieBanner.astro:onReject',message:'reject handler triggered',data:{hasUC:!!window.UC_UI,hasGtag:typeof window.gtag==='function'},timestamp:Date.now()})}).catch(()=>{});
        // #endregion
        const handledByUc = tryUcRejectOptional();
        if (!handledByUc) {
          updateConsentMode(false, false);
        } else {
          applyStateFromHelper();
        }
        setChoiceCookie("rejected");
        hide();
      };

      const onCustomize = () => openCustomize();
      const onSavePreferences = () => {
        const analytics = !!analyticsOpt?.checked;
        const marketing = !!marketingOpt?.checked;
        // #region agent log
        fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',runId:'post-fix',hypothesisId:'H7',location:'CookieBanner.astro:onSavePreferences',message:'fallback preferences saved',data:{analytics:analytics,marketing:marketing},timestamp:Date.now()})}).catch(()=>{});
        // #endregion
        updateConsentMode(analytics, marketing);
        setChoiceCookie("customized");
        hide();
      };

      // Global handlers ensure immediate response even if listener binding fails.
      window.growthroomCookieAccept = onAccept;
      window.growthroomCookieReject = onReject;
      window.growthroomCookieCustomize = onCustomize;
      window.growthroomCookieSavePreferences = onSavePreferences;
      // #region agent log
      fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',runId:'pre-fix',hypothesisId:'H3',location:'CookieBanner.astro:globalHandlers',message:'global handlers assigned',data:{accept:typeof window.growthroomCookieAccept,reject:typeof window.growthroomCookieReject,customize:typeof window.growthroomCookieCustomize},timestamp:Date.now()})}).catch(()=>{});
      // #endregion

      const accept = document.getElementById("cookie-accept");
      const reject = document.getElementById("cookie-reject");
      const customize = document.getElementById("cookie-customize");
      // #region agent log
      fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',runId:'pre-fix',hypothesisId:'H4',location:'CookieBanner.astro:bind',message:'elements resolved for listeners',data:{acceptFound:!!accept,rejectFound:!!reject,customizeFound:!!customize,tagNameAccept:accept&&accept.tagName},timestamp:Date.now()})}).catch(()=>{});
      // #endregion
      // Click behavior uses inline onclick + global handlers to avoid double-binding.

      window.addEventListener("UC_CONSENT", () => {
        // Only persist/close from Customize flow after explicit user action.
        if (!awaitingCustomizeChoice) return;
        awaitingCustomizeChoice = false;
        applyStateFromHelper();
        setChoiceCookie("customized");
        hide();
      });

      window.addEventListener("growthroom:consent-updated", () => {
        if (readChoiceCookie()) {
          hide();
        }
      });

      // Start safe on every load/HMR.
      document.documentElement.style.overflow = "";
      document.body.style.overflow = "";
      banner.classList.add("hidden");

      if (readChoiceCookie()) {
        hide();
      } else {
        show();
      }
      // #region agent log
      fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',runId:'pre-fix',hypothesisId:'H5',location:'CookieBanner.astro:init',message:'initial visibility state',data:{cookie:readChoiceCookie(),isHidden:banner.classList.contains('hidden')},timestamp:Date.now()})}).catch(()=>{});
      // #endregion

      // Permanent guard: if something touches overflow, release it.
      const guard = () => {
        if (!isBannerVisible()) {
          document.documentElement.style.overflow = "";
          document.body.style.overflow = "";
        }
      };
      requestAnimationFrame(guard);
      setTimeout(guard, 200);
      setTimeout(guard, 800);
      window.addEventListener("resize", guard);
      document.addEventListener("visibilitychange", guard);
    } catch (_) {
      // Hard fail-safe: never trap user without scroll.
      document.documentElement.style.overflow = "";
      document.body.style.overflow = "";
    }
  })();
</script>
