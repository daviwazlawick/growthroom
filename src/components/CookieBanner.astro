<style>
  #cookie-banner {
    position: fixed;
    inset: 0;
    z-index: 2147483647;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    background: rgba(0, 0, 0, 0.78);
    backdrop-filter: blur(10px) saturate(130%);
    -webkit-backdrop-filter: blur(10px) saturate(130%);
  }

  #cookie-card {
    position: relative;
    width: 100%;
    max-width: 440px;
    border-radius: 20px;
    border: 1px solid rgba(201, 164, 74, 0.28);
    background: linear-gradient(160deg, rgba(201,164,74,0.10) 0%, rgba(201,164,74,0.03) 100%);
    backdrop-filter: blur(4px);
    padding: 32px;
    box-shadow: 0 0 0 1px rgba(201,164,74,0.18), 0 32px 80px rgba(0,0,0,0.65);
    overflow: hidden;
  }

  /* ambient glow top-right */
  #cookie-card::before {
    content: "";
    pointer-events: none;
    position: absolute;
    top: -60px;
    right: -60px;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: rgba(201,164,74,0.12);
    filter: blur(48px);
  }

  #cookie-fallback-panel {
    margin-top: 20px;
    padding: 16px;
    border-radius: 10px;
    border: 1px solid rgba(201,164,74,0.18);
    background: rgba(201,164,74,0.05);
  }

  .cb-pref-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 9px 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .cb-pref-row:last-of-type { border-bottom: none; }

  .cb-pref-label {
    font-size: 13px;
    color: #e5e5e5;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cb-pref-label small {
    font-size: 11px;
    color: #7a7a72;
    letter-spacing: 0.03em;
  }

  .cb-toggle {
    appearance: none;
    -webkit-appearance: none;
    width: 36px;
    height: 20px;
    border-radius: 20px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.14);
    cursor: pointer;
    position: relative;
    transition: background 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }

  .cb-toggle::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #888;
    top: 2px;
    left: 2px;
    transition: transform 0.2s, background 0.2s;
  }

  .cb-toggle:checked {
    background: #c9a44a;
    border-color: #c9a44a;
  }

  .cb-toggle:checked::after {
    background: #000;
    transform: translateX(16px);
  }

  .cb-toggle:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
</style>

<section id="cookie-banner">
  <div id="cookie-card">

    <!-- Eyebrow chip -->
    <div class="premium-chip inline-flex items-center gap-2 rounded-full px-3 py-1.5 mb-4">
      <span class="h-1.5 w-1.5 rounded-full bg-[#C9A44A] animate-pulse shrink-0"></span>
      <span class="section-label">Privacy & Cookies</span>
    </div>

    <!-- Headline -->
    <h3 class="text-xl font-bold text-white leading-snug" style="font-family:'Montserrat','Inter',sans-serif;letter-spacing:-0.015em;">
      Your data, your choice.
    </h3>

    <!-- Divider -->
    <div class="divider-gold my-4"></div>

    <!-- Body -->
    <p class="text-sm text-zinc-400 leading-relaxed">
      We use necessary cookies to keep the site running. Optional analytics and marketing
      cookies are only loaded with your consent — you can change this at any time.
    </p>

    <!-- Actions -->
    <div class="mt-6 flex flex-wrap gap-2 items-center">
      <button
        id="cookie-reject"
        type="button"
        onclick="window.growthroomCookieReject && window.growthroomCookieReject()"
        class="rounded-lg border border-white/15 px-4 py-2 text-sm font-semibold text-zinc-400 transition hover:bg-white/5 hover:text-zinc-200"
      >
        Reject optional
      </button>
      <button
        id="cookie-customize"
        type="button"
        onclick="window.growthroomCookieCustomize && window.growthroomCookieCustomize()"
        class="rounded-lg border border-[#C9A44A]/35 px-4 py-2 text-sm font-semibold text-[#C9A44A] transition hover:bg-[#C9A44A]/10"
      >
        Customize
      </button>
      <button
        id="cookie-accept"
        type="button"
        onclick="window.growthroomCookieAccept && window.growthroomCookieAccept()"
        class="btn-gold !px-5 !py-2 !text-sm !rounded-lg ml-auto"
      >
        Accept all →
      </button>
    </div>

    <!-- Fallback customize panel -->
    <div id="cookie-fallback-panel" style="display:none;">
      <p class="section-label mb-3">Cookie preferences</p>

      <div class="cb-pref-row">
        <label class="cb-pref-label">
          Necessary
          <small>Always active · required to run the site</small>
        </label>
        <input type="checkbox" class="cb-toggle" checked disabled />
      </div>

      <div class="cb-pref-row">
        <label class="cb-pref-label" for="cookie-opt-analytics">
          Analytics
          <small>Page views &amp; session data</small>
        </label>
        <input id="cookie-opt-analytics" type="checkbox" class="cb-toggle" />
      </div>

      <div class="cb-pref-row">
        <label class="cb-pref-label" for="cookie-opt-marketing">
          Marketing
          <small>Ad targeting &amp; retargeting</small>
        </label>
        <input id="cookie-opt-marketing" type="checkbox" class="cb-toggle" />
      </div>

      <div class="mt-4 flex justify-end">
        <button
          id="cookie-save-preferences"
          type="button"
          onclick="window.growthroomCookieSavePreferences && window.growthroomCookieSavePreferences()"
          class="btn-gold !px-5 !py-2 !text-sm !rounded-lg"
        >
          Save preferences
        </button>
      </div>
    </div>

  </div>
</section>

<script>
  (function () {
    try {
      const banner = document.getElementById("cookie-banner");
      if (!banner) return;

      const CONSENT_COOKIE = "growthroom_cookie_choice_v1";
      const CONSENT_MAX_AGE_DAYS = 180;
      const fallbackPanel = document.getElementById("cookie-fallback-panel");
      const analyticsOpt = document.getElementById("cookie-opt-analytics");
      const marketingOpt = document.getElementById("cookie-opt-marketing");

      let _bannerVisible = false;

      const show = () => {
        _bannerVisible = true;
        banner.style.display = "flex";
        if (fallbackPanel) fallbackPanel.style.display = "none";
        document.documentElement.classList.add("cookie-modal-open");
        document.body.classList.add("cookie-modal-open");
      };

      const hide = () => {
        _bannerVisible = false;
        banner.style.display = "none";
        document.documentElement.classList.remove("cookie-modal-open");
        document.body.classList.remove("cookie-modal-open");
      };

      const setChoiceCookie = (choice) => {
        const maxAge = CONSENT_MAX_AGE_DAYS * 24 * 60 * 60;
        const secure = window.location.protocol === "https:" ? "; Secure" : "";
        document.cookie =
          `${CONSENT_COOKIE}=${encodeURIComponent(choice)}; Path=/; Max-Age=${maxAge}; SameSite=Lax${secure}`;
      };

      const readChoiceCookie = () => {
        const prefix = `${CONSENT_COOKIE}=`;
        const parts = document.cookie.split(";").map((part) => part.trim());
        for (const part of parts) {
          if (part.startsWith(prefix)) {
            return decodeURIComponent(part.slice(prefix.length));
          }
        }
        return "";
      };

      const updateConsentMode = (analytics, marketing) => {
        if (typeof window.gtag !== "function") return;
        window.gtag("consent", "update", {
          analytics_storage: analytics ? "granted" : "denied",
          ad_storage: marketing ? "granted" : "denied",
          ad_user_data: marketing ? "granted" : "denied",
          ad_personalization: marketing ? "granted" : "denied",
        });
        window.dispatchEvent(new CustomEvent("growthroom:consent-updated", {
          detail: { analytics: !!analytics, marketing: !!marketing },
        }));
      };

      const applyStateFromHelper = () => {
        if (typeof window.getGrowthroomConsentState !== "function") return false;
        const state = window.getGrowthroomConsentState();
        updateConsentMode(!!state.analytics, !!state.marketing);
        return true;
      };

      const tryUcAcceptAll = () => {
        try {
          const uc = window.UC_UI;
          if (!uc) return false;
          if (typeof uc.acceptAllServices === "function") { uc.acceptAllServices(); return true; }
          if (typeof uc.acceptAllConsents === "function") { uc.acceptAllConsents(); return true; }
          return false;
        } catch (_) { return false; }
      };

      const tryUcRejectOptional = () => {
        try {
          const uc = window.UC_UI;
          if (!uc) return false;
          if (typeof uc.denyAllServices === "function") { uc.denyAllServices(); return true; }
          if (typeof uc.rejectAllConsents === "function") { uc.rejectAllConsents(); return true; }
          if (typeof uc.denyAllConsents === "function") { uc.denyAllConsents(); return true; }
          return false;
        } catch (_) { return false; }
      };

      let awaitingCustomizeChoice = false;

      const openCustomize = () => {
        awaitingCustomizeChoice = true;
        if (typeof window.openPrivacySettings === "function") {
          hide();
          window.openPrivacySettings();
          return;
        }
        awaitingCustomizeChoice = false;
        if (fallbackPanel) fallbackPanel.style.display = "block";
      };

      const onAccept = () => {
        const handledByUc = tryUcAcceptAll();
        if (!handledByUc) updateConsentMode(true, true);
        else applyStateFromHelper();
        setChoiceCookie("accepted");
        hide();
      };

      const onReject = () => {
        const handledByUc = tryUcRejectOptional();
        if (!handledByUc) updateConsentMode(false, false);
        else applyStateFromHelper();
        setChoiceCookie("rejected");
        hide();
      };

      const onSavePreferences = () => {
        const analytics = !!(analyticsOpt && analyticsOpt.checked);
        const marketing = !!(marketingOpt && marketingOpt.checked);
        updateConsentMode(analytics, marketing);
        setChoiceCookie("customized");
        hide();
      };

      window.growthroomCookieAccept = onAccept;
      window.growthroomCookieReject = onReject;
      window.growthroomCookieCustomize = openCustomize;
      window.growthroomCookieSavePreferences = onSavePreferences;

      window.addEventListener("UC_CONSENT", () => {
        if (!awaitingCustomizeChoice) return;
        awaitingCustomizeChoice = false;
        applyStateFromHelper();
        setChoiceCookie("customized");
        hide();
      });

      window.addEventListener("growthroom:consent-updated", () => {
        if (readChoiceCookie()) hide();
      });

      banner.style.display = "none";

      if (readChoiceCookie()) {
        hide();
      } else {
        show();
      }

      const guard = () => {
        if (!_bannerVisible) {
          document.documentElement.style.overflow = "";
          document.body.style.overflow = "";
        }
      };
      requestAnimationFrame(guard);
      setTimeout(guard, 200);
      setTimeout(guard, 800);
      window.addEventListener("resize", guard);
      document.addEventListener("visibilitychange", guard);
    } catch (_) {
      document.documentElement.style.overflow = "";
      document.body.style.overflow = "";
    }
  })();
</script>
