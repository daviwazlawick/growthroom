<style>
  #cookie-banner {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 2147483647;
    width: 100%;
    max-width: 360px;
  }

  #cookie-card {
    position: relative;
    border-radius: 16px;
    border: 1px solid rgba(201, 164, 74, 0.25);
    background: rgba(10, 10, 8, 0.92);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    padding: 20px 22px;
    box-shadow: 0 0 0 1px rgba(201,164,74,0.12), 0 24px 60px rgba(0,0,0,0.7);
    overflow: hidden;
  }

  #cookie-card::before {
    content: "";
    pointer-events: none;
    position: absolute;
    top: -40px;
    right: -40px;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: rgba(201,164,74,0.08);
    filter: blur(40px);
  }

  #cookie-main { }

  #cookie-prefs {
    display: none;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  #cookie-prefs.open { display: block; }

  .cb-pref-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 0;
  }

  .cb-pref-row + .cb-pref-row {
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .cb-pref-label {
    font-size: 12px;
    font-family: 'Inter', sans-serif;
    color: #d4d4d0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .cb-pref-label small {
    font-size: 10px;
    color: #5a5a52;
    letter-spacing: 0.03em;
  }

  .cb-toggle {
    appearance: none;
    -webkit-appearance: none;
    width: 32px;
    height: 18px;
    border-radius: 18px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.12);
    cursor: pointer;
    position: relative;
    transition: background 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }

  .cb-toggle::after {
    content: "";
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #666;
    top: 2px;
    left: 2px;
    transition: transform 0.2s, background 0.2s;
  }

  .cb-toggle:checked {
    background: #c9a44a;
    border-color: #c9a44a;
  }

  .cb-toggle:checked::after {
    background: #0a0a08;
    transform: translateX(14px);
  }

  .cb-toggle:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  @media (max-width: 420px) {
    #cookie-banner {
      bottom: 0;
      left: 0;
      max-width: 100%;
      border-radius: 0;
    }
    #cookie-card {
      border-radius: 16px 16px 0 0;
    }
  }
</style>

<section id="cookie-banner">
  <div id="cookie-card">

    <div id="cookie-main">
      <p style="font-family:'Montserrat','Inter',sans-serif;font-size:13px;font-weight:700;color:#fff;letter-spacing:-0.01em;margin:0 0 6px;">
        Privacy &amp; Cookies
      </p>
      <p style="font-size:12px;color:#7a7a72;line-height:1.55;margin:0 0 16px;font-family:'Inter',sans-serif;">
        We use necessary cookies to run the site. Optional analytics and marketing cookies load only with your consent.
      </p>

      <div style="display:flex;gap:8px;align-items:center;">
        <button
          id="cookie-reject"
          type="button"
          onclick="window.growthroomCookieReject && window.growthroomCookieReject()"
          style="flex:1;border-radius:8px;border:1px solid rgba(255,255,255,0.12);padding:8px 12px;font-size:12px;font-weight:600;color:#7a7a72;background:transparent;cursor:pointer;font-family:'Inter',sans-serif;transition:color 0.15s,border-color 0.15s;"
          onmouseover="this.style.color='#d4d4d0';this.style.borderColor='rgba(255,255,255,0.22)'"
          onmouseout="this.style.color='#7a7a72';this.style.borderColor='rgba(255,255,255,0.12)'"
        >
          Reject optional
        </button>
        <button
          id="cookie-accept"
          type="button"
          onclick="window.growthroomCookieAccept && window.growthroomCookieAccept()"
          class="btn-gold"
          style="flex:1;padding:8px 12px !important;font-size:12px !important;border-radius:8px !important;"
        >
          Accept all →
        </button>
      </div>

      <div style="margin-top:10px;text-align:center;">
        <button
          id="cookie-customize"
          type="button"
          onclick="window.growthroomCookieCustomize && window.growthroomCookieCustomize()"
          style="background:none;border:none;font-size:11px;color:#5a5a52;cursor:pointer;font-family:'Inter',sans-serif;text-decoration:underline;text-underline-offset:2px;"
          onmouseover="this.style.color='#c9a44a'"
          onmouseout="this.style.color='#5a5a52'"
        >
          Customize preferences
        </button>
      </div>
    </div>

    <div id="cookie-prefs">
      <div class="cb-pref-row">
        <label class="cb-pref-label">
          Necessary
          <small>Always active</small>
        </label>
        <input type="checkbox" class="cb-toggle" checked disabled />
      </div>
      <div class="cb-pref-row">
        <label class="cb-pref-label" for="cookie-opt-analytics">
          Analytics
          <small>Page views &amp; sessions</small>
        </label>
        <input id="cookie-opt-analytics" type="checkbox" class="cb-toggle" />
      </div>
      <div class="cb-pref-row">
        <label class="cb-pref-label" for="cookie-opt-marketing">
          Marketing
          <small>Ad targeting</small>
        </label>
        <input id="cookie-opt-marketing" type="checkbox" class="cb-toggle" />
      </div>
      <div style="margin-top:12px;display:flex;justify-content:flex-end;">
        <button
          id="cookie-save-preferences"
          type="button"
          onclick="window.growthroomCookieSavePreferences && window.growthroomCookieSavePreferences()"
          class="btn-gold"
          style="padding:7px 16px !important;font-size:12px !important;border-radius:8px !important;"
        >
          Save preferences
        </button>
      </div>
    </div>

  </div>
</section>

<script>
  (function () {
    try {
      const banner = document.getElementById("cookie-banner");
      if (!banner) return;

      const CONSENT_COOKIE = "growthroom_cookie_choice_v1";
      const CONSENT_MAX_AGE_DAYS = 180;
      const prefsPanel = document.getElementById("cookie-prefs");
      const analyticsOpt = document.getElementById("cookie-opt-analytics");
      const marketingOpt = document.getElementById("cookie-opt-marketing");

      let _bannerVisible = false;

      const show = () => {
        _bannerVisible = true;
        banner.style.display = "block";
        document.documentElement.classList.add("cookie-modal-open");
        document.body.classList.add("cookie-modal-open");
      };

      const hide = () => {
        _bannerVisible = false;
        banner.style.display = "none";
        document.documentElement.classList.remove("cookie-modal-open");
        document.body.classList.remove("cookie-modal-open");
      };

      const setChoiceCookie = (choice) => {
        const maxAge = CONSENT_MAX_AGE_DAYS * 24 * 60 * 60;
        const secure = window.location.protocol === "https:" ? "; Secure" : "";
        document.cookie =
          `${CONSENT_COOKIE}=${encodeURIComponent(choice)}; Path=/; Max-Age=${maxAge}; SameSite=Lax${secure}`;
      };

      const readChoiceCookie = () => {
        const prefix = `${CONSENT_COOKIE}=`;
        const parts = document.cookie.split(";").map((part) => part.trim());
        for (const part of parts) {
          if (part.startsWith(prefix)) {
            return decodeURIComponent(part.slice(prefix.length));
          }
        }
        return "";
      };

      const updateConsentMode = (analytics, marketing) => {
        if (typeof window.gtag !== "function") return;
        window.gtag("consent", "update", {
          analytics_storage: analytics ? "granted" : "denied",
          ad_storage: marketing ? "granted" : "denied",
          ad_user_data: marketing ? "granted" : "denied",
          ad_personalization: marketing ? "granted" : "denied",
        });
        window.dispatchEvent(new CustomEvent("growthroom:consent-updated", {
          detail: { analytics: !!analytics, marketing: !!marketing },
        }));
      };

      const applyStateFromHelper = () => {
        if (typeof window.getGrowthroomConsentState !== "function") return false;
        const state = window.getGrowthroomConsentState();
        updateConsentMode(!!state.analytics, !!state.marketing);
        return true;
      };

      const tryUcAcceptAll = () => {
        try {
          const uc = window.UC_UI;
          if (!uc) return false;
          if (typeof uc.acceptAllServices === "function") { uc.acceptAllServices(); return true; }
          if (typeof uc.acceptAllConsents === "function") { uc.acceptAllConsents(); return true; }
          return false;
        } catch (_) { return false; }
      };

      const tryUcRejectOptional = () => {
        try {
          const uc = window.UC_UI;
          if (!uc) return false;
          if (typeof uc.denyAllServices === "function") { uc.denyAllServices(); return true; }
          if (typeof uc.rejectAllConsents === "function") { uc.rejectAllConsents(); return true; }
          if (typeof uc.denyAllConsents === "function") { uc.denyAllConsents(); return true; }
          return false;
        } catch (_) { return false; }
      };

      let awaitingCustomizeChoice = false;

      const openCustomize = () => {
        awaitingCustomizeChoice = true;
        if (typeof window.openPrivacySettings === "function") {
          hide();
          window.openPrivacySettings();
          return;
        }
        awaitingCustomizeChoice = false;
        if (prefsPanel) prefsPanel.classList.add("open");
      };

      const onAccept = () => {
        const handledByUc = tryUcAcceptAll();
        if (!handledByUc) updateConsentMode(true, true);
        else applyStateFromHelper();
        setChoiceCookie("accepted");
        hide();
      };

      const onReject = () => {
        const handledByUc = tryUcRejectOptional();
        if (!handledByUc) updateConsentMode(false, false);
        else applyStateFromHelper();
        setChoiceCookie("rejected");
        hide();
      };

      const onSavePreferences = () => {
        const analytics = !!(analyticsOpt && analyticsOpt.checked);
        const marketing = !!(marketingOpt && marketingOpt.checked);
        updateConsentMode(analytics, marketing);
        setChoiceCookie("customized");
        hide();
      };

      window.growthroomCookieAccept = onAccept;
      window.growthroomCookieReject = onReject;
      window.growthroomCookieCustomize = openCustomize;
      window.growthroomCookieSavePreferences = onSavePreferences;

      window.addEventListener("UC_CONSENT", () => {
        if (!awaitingCustomizeChoice) return;
        awaitingCustomizeChoice = false;
        applyStateFromHelper();
        setChoiceCookie("customized");
        hide();
      });

      window.addEventListener("growthroom:consent-updated", () => {
        if (readChoiceCookie()) hide();
      });

      banner.style.display = "none";

      if (readChoiceCookie()) {
        hide();
      } else {
        show();
      }

      const guard = () => {
        if (!_bannerVisible) {
          document.documentElement.style.overflow = "";
          document.body.style.overflow = "";
        }
      };
      requestAnimationFrame(guard);
      setTimeout(guard, 200);
      setTimeout(guard, 800);
      window.addEventListener("resize", guard);
      document.addEventListener("visibilitychange", guard);
    } catch (_) {
      document.documentElement.style.overflow = "";
      document.body.style.overflow = "";
    }
  })();
</script>
