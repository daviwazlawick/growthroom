---
interface Props {
  waitlistUrl: string;
}
const { waitlistUrl } = Astro.props;
const heroImg = "/img/ChatGPT%20Image%20Apr%2024,%202026,%2011_34_26%20AM.png";
---

<section class="relative min-h-screen flex items-center pt-28 lg:pt-14 pb-20 overflow-hidden border-b border-white/8">
  <!-- Decorative grid lines -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.025]"
       style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 64px 64px;">
  </div>

  <div class="relative mx-auto w-full max-w-6xl px-6 sm:px-8">
    <div class="grid lg:grid-cols-2 gap-14 lg:gap-10 items-center">

      <!-- ── Left: copy ── -->
      <div>
        <!-- Chip -->
        <div class="reveal premium-chip inline-flex items-center gap-2.5 rounded-full px-4 py-2">
          <span class="h-1.5 w-1.5 rounded-full bg-[#C9A44A] shrink-0"></span>
          <span class="section-label">Growth Room · Early Access</span>
        </div>

        <!-- Headline -->
        <h1 class="reveal d1 mt-7 text-[2.75rem] font-black leading-[1.03] sm:text-[3.5rem] lg:text-[3.75rem]">
          Scale paid traffic profitably in 30 days.<br />
          <span class="text-[#C9A44A]">For founders already spending on ads.</span>
        </h1>

        <p class="reveal d2 mt-6 max-w-lg text-[1.1rem] leading-relaxed text-zinc-300">
          Join the private waitlist before the next cohort opens.
          Start with a free 15-min expert intro and pay nothing until you're matched to a specific Growth Room.
        </p>

        <!-- CTAs -->
        <div class="reveal d3 mt-10 flex flex-wrap items-center gap-4">
          <a href={waitlistUrl} class="btn-gold">
            Reserve Your Spot →
          </a>
          <p class="text-sm text-zinc-500">Takes 10 seconds. No spam.</p>
        </div>

        <!-- Feature pills -->
        <div class="reveal d4 mt-10 flex flex-wrap gap-2">
          {[
            { label: "Limited Seats" },
            { label: "Free Expert Intro" },
            { label: "No Cost Until Match" },
            { label: "Weekly Live Reviews" },
          ].map(({ label }) => (
            <span class="inline-flex items-center gap-2 rounded-full border border-white/12 bg-white/5 px-4 py-1.5 text-xs font-semibold tracking-wide text-zinc-300">
              {label}
            </span>
          ))}
        </div>
      </div>

      <!-- ── Right: hero image ── -->
      <div class="reveal d2 relative flex justify-center lg:justify-end">
        <div class="relative w-full max-w-lg">
          <!-- Glow -->
          <div class="absolute -inset-6 rounded-3xl bg-[#C9A44A]/10 blur-3xl pointer-events-none"></div>

          <!-- Image frame -->
          <div class="relative overflow-hidden rounded-2xl border border-[#C9A44A]/30 shadow-[0_32px_80px_rgba(0,0,0,0.7)]">
            <img
              src={heroImg}
              alt="Growth Room weekly mastermind session — turning spend into real growth"
              class="w-full object-cover"
              loading="eager"
              width="800"
              height="450"
            />
            <!-- Subtle vignette overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent pointer-events-none"></div>
          </div>

          <!-- Floating stat badge -->
          <div class="absolute -bottom-5 -left-4 sm:-left-8 glass-card rounded-xl px-4 py-3 shadow-2xl border border-[#C9A44A]/25">
            <p class="text-[10px] font-semibold uppercase tracking-widest text-zinc-400">Early access capacity</p>
            <p class="mt-0.5 text-lg font-black">Only <span id="spots-badge" class="text-red-500">50</span> spots</p>
          </div>

          <!-- Top badge -->
          <div class="absolute -top-4 -right-3 sm:-right-5 glass-card rounded-xl px-4 py-3 shadow-xl border border-white/12">
            <p class="text-[10px] font-semibold uppercase tracking-widest text-zinc-400">Waitlist momentum</p>
            <p class="mt-0.5 text-lg font-black text-white"><span id="joined-count" class="text-emerald-400">0</span> joined <span class="text-emerald-400 text-sm font-semibold">this cycle</span></p>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom stats bar -->
    <div class="reveal d5 mt-20 divider-gold"></div>
    <div class="reveal mt-8 grid grid-cols-3 gap-4 sm:gap-8 text-center">
      {[
        { value: "spots-stat", label: "Early access spots available" },
        { value: "15 min",   label: "Free intro with an expert" },
        { value: "€0",   label: "Cost before Growth Room match" },
      ].map(({ value, label }) => (
        <div class="flex flex-col items-center gap-1">
          {value === "spots-stat"
            ? <span id="spots-stat" class="text-2xl font-black text-red-500 sm:text-3xl">50</span>
            : <span class="text-2xl font-black text-[#C9A44A] sm:text-3xl">{value}</span>
          }
          <span class="text-xs text-zinc-500 sm:text-sm">{label}</span>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="reveal mt-10 flex flex-col items-center gap-3">
      <a href={waitlistUrl} class="btn-gold text-base px-8 py-3">
        Get Now Your Free Call →
      </a>
    </div>
  </div>
</section>

<script>
  function animateSpots() {
    const els = [document.getElementById('spots-badge'), document.getElementById('spots-stat')];
    const start = 50;
    const end = 18;
    const duration = 2200; // ms
    const startTime = performance.now();

    function easeOut(t: number) {
      return 1 - Math.pow(1 - t, 3);
    }

    function tick(now: number) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased = easeOut(progress);
      const current = Math.round(start - eased * (start - end));

      els.forEach(el => { if (el) el.textContent = String(current); });

      if (progress < 1) {
        requestAnimationFrame(tick);
      }
    }

    requestAnimationFrame(tick);
  }

  function animateJoined() {
    const el = document.getElementById('joined-count');
    if (!el) return;
    const target = el;
    const end = 32;
    const duration = 1800;
    const startTime = performance.now();

    function tick(now: number) {
      const progress = Math.min((now - startTime) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      target.textContent = String(Math.round(eased * end));
      if (progress < 1) requestAnimationFrame(tick);
    }

    target.textContent = '0';
    requestAnimationFrame(tick);
  }

  function startLoop() {
    animateSpots();
    animateJoined();
    setInterval(() => { animateSpots(); animateJoined(); }, 15000);
  }

  if (document.readyState === 'complete') {
    startLoop();
  } else {
    window.addEventListener('load', startLoop);
  }
</script>
