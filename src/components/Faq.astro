---
interface Props {
  waitlistUrl: string;
}
const { waitlistUrl } = Astro.props;

const faqs = [
  {
    q: "Do I pay anything to join the waitlist?",
    a: "No. Waitlist registration is free, and there is no payment before you are matched to a specific Growth Room.",
  },
  {
    q: "What happens after I register?",
    a: "You receive a scheduling link for a free 15-minute intro with an expert. We review fit and your current bottleneck.",
  },
  {
    q: "Is this for beginners?",
    a: "Yes. We support both beginners and experienced operators. If you are just starting, you can join beginner rooms designed to help you launch paid media correctly without wasting unnecessary budget.",
  },
  {
    q: "Why should I join now?",
    a: "Seats are limited per intake. Early-access applicants are prioritized before public rollout.",
  },
];
---

<section class="border-b border-gray-200" style="background:#ffffff;">
  <div class="mx-auto w-full max-w-6xl px-6 py-24 sm:px-8 sm:py-32">
    <div class="reveal text-center">
      <p class="section-label-dark">FAQ</p>
      <h2 class="mt-4 text-3xl font-bold text-gray-900 sm:text-[2.75rem]">
        Remove every reason to wait.
      </h2>
    </div>

    <div class="mt-12 space-y-4">
      {faqs.map(({ q, a }, i) => (
        <div class={`reveal d${i + 1} card-light rounded-2xl p-7`}>
          <h3 class="text-lg font-bold text-gray-900">{q}</h3>
          <p class="mt-2 text-[15px] leading-relaxed text-gray-600">{a}</p>
        </div>
      ))}
    </div>

    <div class="reveal mt-10">
      <a href={waitlistUrl} class="btn-gold">
        Reserve Your Spot →
      </a>
      <p class="mt-3 text-sm text-gray-500">
        Free 15-min expert intro after waitlist registration.<br />
        No cost until you're matched to a specific Growth Room.
      </p>
    </div>
  </div>
</section>
