---
import "../styles/global.css";
import MetaEventId from "../components/MetaEventId.astro";
import CookieBanner from "../components/CookieBanner.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Growth Room | Weekly Expert Access",
  description = "Weekly mastermind for entrepreneurs running paid ads who want consistent results.",
} = Astro.props;

const GTM_ID = import.meta.env.PUBLIC_GTM_ID || "GTM-TD9BJC9F";
const USERCENTRICS_SETTINGS_ID = import.meta.env.PUBLIC_USERCENTRICS_SETTINGS_ID || "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- 1º: event_id gerado ANTES de qualquer tag de marketing -->
    <MetaEventId />

    <!-- 2º: Consent Mode v2 default (strict prior blocking) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      window.gtag = window.gtag || gtag;

      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        functionality_storage: 'granted',
        security_storage: 'granted',
        wait_for_update: 1500
      });
    </script>

    <!-- 3º: Usercentrics CMP loader + bridge to Consent Mode v2 -->
    {USERCENTRICS_SETTINGS_ID && (
      <>
        <script
          id="usercentrics-cmp"
          async
          src="https://app.usercentrics.eu/browser-ui/latest/loader.js"
          data-settings-id={USERCENTRICS_SETTINGS_ID}
        ></script>
        <script is:inline>
          (function () {
            function toGranted(value) {
              return value ? 'granted' : 'denied';
            }

            function readConsentState() {
              var analytics = false;
              var marketing = false;
              try {
                if (window.UC_UI && typeof window.UC_UI.getServicesBaseInfo === 'function') {
                  var services = window.UC_UI.getServicesBaseInfo() || [];
                  for (var i = 0; i < services.length; i++) {
                    var svc = services[i];
                    var name = (svc.name || '').toLowerCase();
                    var category = (svc.categorySlug || svc.category || '').toLowerCase();
                    var granted = !!(svc.consent && svc.consent.status);
                    if (!granted) continue;
                    if (category.indexOf('marketing') !== -1 || name.indexOf('facebook') !== -1 || name.indexOf('ads') !== -1) {
                      marketing = true;
                    }
                    if (category.indexOf('analytics') !== -1 || name.indexOf('analytics') !== -1 || name.indexOf('google analytics') !== -1) {
                      analytics = true;
                    }
                  }
                }
              } catch (_) {}
              return { analytics: analytics, marketing: marketing };
            }

            function applyConsentModeV2() {
              var state = readConsentState();
              window.gtag('consent', 'update', {
                analytics_storage: toGranted(state.analytics),
                ad_storage: toGranted(state.marketing),
                ad_user_data: toGranted(state.marketing),
                ad_personalization: toGranted(state.marketing),
              });
              window.dispatchEvent(new CustomEvent('growthroom:consent-updated', { detail: state }));
            }

            function registerHooks() {
              applyConsentModeV2();
              window.addEventListener('UC_UI_INITIALIZED', applyConsentModeV2);
              window.addEventListener('UC_UI_VIEW_CHANGED', applyConsentModeV2);
              window.addEventListener('UC_CONSENT', applyConsentModeV2);
            }

            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', registerHooks);
            } else {
              registerHooks();
            }

            window.getGrowthroomConsentState = readConsentState;

            window.openPrivacySettings = function () {
              try {
                if (window.UC_UI && typeof window.UC_UI.showSecondLayer === 'function') {
                  window.UC_UI.showSecondLayer();
                  return;
                }
                if (window.UC_UI && typeof window.UC_UI.showFirstLayer === 'function') {
                  window.UC_UI.showFirstLayer();
                }
              } catch (_) {}
            };
          })();
        </script>
      </>
    )}

    <!-- 4º: GTM loader (only after consent) -->
    <script is:inline define:vars={{ GTM_ID }}>
      (function () {
        function debug(message, data, hypothesisId, runId) {
          fetch('http://127.0.0.1:7483/ingest/4a08c514-3be5-4074-b836-26384ed65e06',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'f3909c'},body:JSON.stringify({sessionId:'f3909c',location:'Layout.astro:gtmLoader',message:message,data:data,timestamp:Date.now(),hypothesisId:hypothesisId,runId:runId})}).catch(()=>{});
        }

        function loadGtmOnce() {
          if (!GTM_ID || window.__growthroomGtmLoaded) return;
          window.__growthroomGtmLoaded = true;
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
          var f = document.getElementsByTagName('script')[0];
          var j = document.createElement('script');
          var dl = 'dataLayer' !== 'dataLayer' ? '&l=dataLayer' : '';
          j.async = true;
          j.src = 'https://www.googletagmanager.com/gtm.js?id=' + GTM_ID + dl;
          f.parentNode.insertBefore(j, f);
          debug('GTM loaded', { gtmId: GTM_ID }, 'H8', 'post-fix');
        }

        function shouldLoadByCookie() {
          return document.cookie.indexOf('growthroom_cookie_choice_v1=accepted') !== -1 ||
            document.cookie.indexOf('growthroom_cookie_choice_v1=customized') !== -1;
        }

        if (shouldLoadByCookie()) {
          gtag('consent', 'update', {
            analytics_storage: 'granted',
            ad_storage: 'granted',
            ad_user_data: 'granted',
            ad_personalization: 'granted',
          });
          loadGtmOnce();
        } else {
          debug('GTM blocked by cookie gate', { cookie: document.cookie }, 'H8', 'post-fix');
        }

        window.addEventListener('growthroom:consent-updated', function (e) {
          var detail = e && e.detail ? e.detail : {};
          if (detail.analytics || detail.marketing) {
            loadGtmOnce();
          } else {
            debug('Consent update kept GTM blocked', detail, 'H8', 'post-fix');
          }
        });
      })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/img/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="antialiased">
    <slot />
    <CookieBanner />
  </body>
</html>

<script>
  // Intersection Observer para animações de reveal
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>
